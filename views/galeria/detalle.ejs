<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías elegantes -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .detail-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 40px 0 80px 0;
        font-family: 'Inter', sans-serif;
        display: flex;
        align-items: center;
    }

    /* PANEL MÁS ANCHO Y RECTANGULAR */
    .detail-card-panoramic {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 12px; /* Bordes menos pronunciados */
        overflow: hidden;
        max-width: 1400px; /* Panel mucho más ancho hacia los lados */
        width: 95%;
        margin: 0 auto;
        box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    }

    /* CONTENEDOR DE IMAGEN CON EFECTO ZOOM */
    .img-column-detail {
        background: #000;
        overflow: hidden; /* Importante para el efecto zoom */
        position: relative;
        min-height: 600px;
    }

    .img-detail-pano {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1), opacity 0.5s ease;
        cursor: zoom-in;
    }

    /* EFECTO HOVER: Mostrar imagen completa/detalles */
    .img-column-detail:hover .img-detail-pano {
        transform: scale(1.15); /* Zoom elegante */
        opacity: 1;
    }

    /* CONTENIDO DE TEXTO */
    .info-pane-wide {
        padding: 60px 80px; /* Más espacio lateral interno */
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .category-label-styled {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--at-orange);
        margin-bottom: 20px;
        padding: 5px 15px;
        border: 1px solid var(--at-orange);
        background: rgba(249, 115, 22, 0.05);
        border-radius: 4px;
        width: fit-content;
    }

    .obra-title-pano {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 900;
        color: white;
        line-height: 1.1;
        margin-bottom: 15px;
        letter-spacing: -2px;
    }

    .artist-link-pano {
        font-size: 1.1rem;
        color: #94a3b8;
        margin-bottom: 30px;
    }

    .artist-link-pano a {
        color: var(--at-orange) !important;
        text-decoration: none;
        font-weight: 700;
        transition: 0.3s;
    }

    .artist-link-pano a:hover { color: white !important; }

    .price-value-pano {
        font-size: 3rem;
        font-weight: 800;
        color: white;
        margin-bottom: 40px;
    }

    /* FICHA TÉCNICA */
    .specs-box-modern {
        background: rgba(0,0,0,0.2);
        border: 1px solid var(--at-border);
        border-radius: 8px;
        padding: 30px;
        margin-bottom: 40px;
    }

    .specs-header-label {
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 20px;
        display: block;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding-bottom: 10px;
    }

    .spec-row-item {
        background: transparent !important;
        color: #e2e8f0 !important;
        border-bottom: 1px solid rgba(255,255,255,0.03) !important;
        padding: 12px 0 !important;
        font-size: 0.95rem;
        display: flex;
        justify-content: space-between;
    }

    .spec-row-item:last-child { border: none !important; }
    .spec-row-item strong { color: #94a3b8; font-weight: 500; }

    /* BOTONES */
    .btn-purchase {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 18px 0;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(249, 115, 22, 0.2);
    }

    .btn-purchase:hover { transform: translateY(-3px); filter: brightness(1.1); }

    .btn-back-outline {
        background: transparent;
        color: #cbd5e1;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 14px 0;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: 0.3s;
        margin-top: 15px;
    }

    .btn-back-outline:hover { border-color: white; color: white; background: rgba(255,255,255,0.03); }

    @media (max-width: 992px) {
        .img-column-detail { min-height: 400px; }
        .info-pane-wide { padding: 40px; }
        .obra-title-pano { font-size: 2.8rem; }
    }

    /* ========== LIGHTBOX MODAL ========== */
    .image-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .image-modal-overlay.active {
        display: flex;
        opacity: 1;
    }

    .modal-close-btn {
        position: absolute;
        top: 20px;
        right: 30px;
        color: white;
        font-size: 2.5rem;
        font-weight: 300;
        cursor: pointer;
        z-index: 10001;
        transition: color 0.2s, transform 0.2s;
        line-height: 1;
        user-select: none;
    }

    .modal-close-btn:hover {
        color: var(--at-orange);
        transform: scale(1.2);
    }

    .modal-zoom-controls {
        position: absolute;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 12px;
        z-index: 10001;
    }

    .modal-zoom-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.3);
        background: rgba(0,0,0,0.6);
        color: white;
        font-size: 1.4rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        backdrop-filter: blur(8px);
        user-select: none;
    }

    .modal-zoom-btn:hover {
        background: var(--at-orange);
        border-color: var(--at-orange);
    }

    .modal-zoom-indicator {
        position: absolute;
        bottom: 90px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.6);
        font-size: 0.8rem;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        letter-spacing: 1px;
        z-index: 10001;
        pointer-events: none;
        transition: opacity 0.3s;
    }

    .modal-img-container {
        max-width: 95vw;
        max-height: 95vh;
        overflow: hidden;
        cursor: grab;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-img-container.dragging {
        cursor: grabbing;
    }

    .modal-img {
        max-width: 95vw;
        max-height: 95vh;
        width: 90vw;
        height: 90vh;
        object-fit: contain;
        transition: transform 0.15s ease-out;
        transform-origin: center center;
        pointer-events: none;
        user-select: none;
    }

    .modal-hint {
        position: absolute;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.5);
        font-size: 0.75rem;
        font-family: 'Inter', sans-serif;
        letter-spacing: 1px;
        z-index: 10001;
        pointer-events: none;
        animation: fadeHint 3s forwards;
    }

    @keyframes fadeHint {
        0%, 70% { opacity: 1; }
        100% { opacity: 0; }
    }

    /* Cursor zoom-in en la imagen del detalle */
    .img-detail-pano {
        cursor: zoom-in;
    }
</style>

<div class="detail-wrapper">
    <% 
        /* LÓGICA DE FORMATEO COMPACTO PROFESIONAL (K, M, B, T, P, E) */
        const formatShorthandMetric = (val) => {
            if (val === undefined || val === null) return '0';
            
            // Sanitizar la cadena eliminando símbolos de dólar, comas de miles o espacios
            let cleanVal = String(val).replace(/[^0-9.-]/g, '');
            
            // Si el formato viene con comas para decimales, normalizar a punto
            if (String(val).includes(',') && !String(val).includes('.')) {
                cleanVal = String(val).replace(/[^0-9,-]/g, '').replace(',', '.');
            }
            
            const num = parseFloat(cleanVal);
            if (isNaN(num) || num === 0) return '0';
            
            const absolute = Math.abs(num);
            const sign = num < 0 ? '-' : '';
            
            if (absolute >= 1e18) { // Quintillones (E)
                return sign + (absolute / 1e18).toFixed(1).replace(/\.0$/, '') + 'E';
            }
            if (absolute >= 1e15) { // Cuadrillones (P)
                return sign + (absolute / 1e15).toFixed(1).replace(/\.0$/, '') + 'P';
            }
            if (absolute >= 1e12) { // Billones (T)
                return sign + (absolute / 1e12).toFixed(1).replace(/\.0$/, '') + 'T';
            }
            if (absolute >= 1e9) {  // Miles de millones (B)
                return sign + (absolute / 1e9).toFixed(1).replace(/\.0$/, '') + 'B';
            }
            if (absolute >= 1e6) {  // Millones (M)
                return sign + (absolute / 1e6).toFixed(1).replace(/\.0$/, '') + 'M';
            }
            if (absolute >= 1e3) {  // Miles (K)
                return sign + (absolute / 1e3).toFixed(1).replace(/\.0$/, '') + 'K';
            }
            return sign + num.toLocaleString('en-US', { maximumFractionDigits: 1 });
        };
    %>

    <div class="container-fluid">
        <div class="detail-card-panoramic shadow-2xl">
            <div class="row g-0">
                <!-- Columna Imagen (Aumentada para lucir la obra) -->
                <div class="col-lg-7 img-column-detail">
                    <img src="<%= (obra.foto && obra.foto.startsWith('http')) ? obra.foto : ('/uploads/' + (obra.foto || 'default_obra.jpg')) %>" class="img-detail-pano" alt="<%= obra.nombre %>">
                </div>
                
                <!-- Columna Datos -->
                <div class="col-lg-5 info-pane-wide">
                    <div class="category-label-styled"><%= obra.nombre_genero %></div>
                    
                    <h1 class="obra-title-pano"><%= obra.nombre %></h1>
                    
                    <p class="artist-link-pano">
                        Obra certificada de: <a href="/galeria/artista/<%= obra.autor_id %>">
                            <%= obra.nombre_artista %> <%= obra.apellido_artista %>
                        </a>
                    </p>
                    
                    <!-- Precio compacto asimétrico de alta gama en la vista de detalle -->
                    <div class="price-value-pano">$<%= formatShorthandMetric(obra.precioObra) %></div>

                    <!-- FICHA TÉCNICA -->
                    <div class="specs-box-modern">
                        <% const fmt2 = (v) => Number.isFinite(Number(v)) ? Number(v).toFixed(2) : '0.00'; %>
                        <span class="specs-header-label">Ficha Técnica</span>
                        <div class="spec-row-item"><strong>Origen</strong><span><%= obra.nacionalidad %></span></div>

                        <% if (obra.detalles && typeof obra.detalles === 'object' && Object.keys(obra.detalles).length > 0) { %>
                            <% const labels = {
                                material: 'Material', peso: 'Peso', altura: 'Altura',
                                largo: 'Largo', ancho: 'Ancho', profundidad: 'Profundidad',
                                tecnica: 'Técnica', soporte: 'Soporte', tipo_foto: 'Tipo',
                                papel: 'Papel', formato: 'Formato', tipoArcilla: 'Arcilla',
                                temperaturaCoccion: 'Temperatura', metal: 'Metal', pureza: 'Pureza',
                                piedraPreciosa: 'Gemas', antigua: 'Antigua'
                            }; %>
                            <% Object.keys(obra.detalles).forEach(key => { %>
                                <% const val = obra.detalles[key]; %>
                                <% if (val !== null && val !== undefined && val !== '') { %>
                                    <% 
                                        const isNumeric = ['peso', 'altura', 'largo', 'ancho', 'profundidad', 'temperaturaCoccion'].includes(key);
                                        const isBoolean = String(val).toLowerCase() === 'true' || String(val).toLowerCase() === 'false';
                                        let displayVal;
                                        if (isBoolean) {
                                            displayVal = String(val).toLowerCase() === 'true' ? 'Sí' : 'No';
                                        } else if (isNumeric) {
                                            displayVal = fmt2(val) + (key === 'temperaturaCoccion' ? ' °C' : key === 'peso' ? ' Kg' : ' cm');
                                        } else {
                                            displayVal = val;
                                        }
                                    %>
                                    <div class="spec-row-item">
                                        <strong><%= labels[key] || key.charAt(0).toUpperCase() + key.slice(1) %></strong>
                                        <span><%= displayVal %></span>
                                    </div>
                                <% } %>
                            <% }); %>
                        <% } %>
                    </div>

                    <div class="d-grid gap-2">
                        <% if (locals.usuario && (locals.usuario.rol === 1 || locals.usuario.rol === 3)) { %>
                            
                            <button class="btn btn-secondary w-100 disabled" style="padding: 18px 0; font-weight: 800; text-transform: uppercase; cursor: not-allowed; opacity: 0.6; border-radius: 100px;">
                                 Acción no permitida para Administradores
                            </button>
                        <% } else { %>
                            <button onclick="intentarComprar('<%= obra.id %>', '<%= obra.nombre %>')" class="btn btn-purchase">
                                Comprar
                            </button>
                        <% } %>
                        <a href="/galeria" class="btn btn-back-outline">
                            ← Volver al Catálogo
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- LIGHTBOX MODAL -->
<div id="imageModal" class="image-modal-overlay">
    <span class="modal-hint">SCROLL PARA ZOOM • ARRASTRA PARA MOVER</span>
    <span class="modal-close-btn" onclick="closeModal()">&times;</span>
    <div class="modal-img-container" id="modalContainer">
        <img id="modalImg" class="modal-img" src="" alt="Zoom obra">
    </div>
    <div class="modal-zoom-indicator" id="zoomIndicator">100%</div>
    <div class="modal-zoom-controls">
        <button class="modal-zoom-btn" onclick="zoomModal(-0.3)" title="Alejar">−</button>
        <button class="modal-zoom-btn" onclick="resetZoom()" title="Restablecer">⟲</button>
        <button class="modal-zoom-btn" onclick="zoomModal(0.3)" title="Acercar">+</button>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
    async function intentarComprar(idObra, nombreObra) {
        try {
            const sessionRes = await fetch('/auth/check-session');
            const sessionData = await sessionRes.json();

            if (!sessionData.loggedIn) {
                window.location.href = '/auth/login?mensaje=Debes iniciar sesión primero';
                return;
            }

            const res = await fetch(`/galeria/api/verificar/${idObra}`);
            const data = await res.json();

            if (data.disponible) {
                window.location.href = `/pagos/confirmar-reserva?obraId=${idObra}&obraNombre=${encodeURIComponent(nombreObra)}`;
            } else {
                alert(`Lo sentimos, la obra "${nombreObra}" ya no está disponible. Estatus actual: ${data.estatus}`);
                window.location.reload();
            }

        } catch (err) {
            console.error(err);
            alert('Ocurrió un error de conexión. Intente nuevamente.');
        }
    }

    /* ========== LIGHTBOX ========== */
    (function() {
        const modal = document.getElementById('imageModal');
        const modalImg = document.getElementById('modalImg');
        const container = document.getElementById('modalContainer');
        const indicator = document.getElementById('zoomIndicator');
        const imgDetail = document.querySelector('.img-detail-pano');

        let scale = 1;
        let posX = 0, posY = 0;
        let isDragging = false;
        let startX, startY;
        let lastTouchDist = 0;

        function updateTransform() {
            modalImg.style.transform = `translate(${posX}px, ${posY}px) scale(${scale})`;
            indicator.textContent = Math.round(scale * 100) + '%';
            indicator.style.opacity = scale > 1 ? '1' : '0';
            container.style.cursor = scale > 1 ? 'grab' : 'default';
        }

        function clampPosition() {
            if (scale <= 1) { posX = 0; posY = 0; return; }
            const rect = container.getBoundingClientRect();
            const imgW = modalImg.offsetWidth * scale;
            const imgH = modalImg.offsetHeight * scale;
            const maxX = Math.max(0, (imgW - rect.width) / 2);
            const maxY = Math.max(0, (imgH - rect.height) / 2);
            posX = Math.max(-maxX, Math.min(maxX, posX));
            posY = Math.max(-maxY, Math.min(maxY, posY));
        }

        function resetAll() {
            scale = 1; posX = 0; posY = 0;
            modalImg.style.transition = 'transform 0.3s ease';
            updateTransform();
            setTimeout(() => { modalImg.style.transition = 'transform 0.15s ease-out'; }, 300);
        }

        window.openModal = function(src) {
            modalImg.src = src;
            resetAll();
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        };

        window.closeModal = function() {
            modal.classList.remove('active');
            document.body.style.overflow = '';
            setTimeout(resetAll, 300);
        };

        window.zoomModal = function(delta) {
            scale = Math.max(0.5, Math.min(4, scale + delta));
            clampPosition();
            updateTransform();
        };

        window.resetZoom = function() { resetAll(); };

        // Click en la imagen del detalle abre el modal
        imgDetail.addEventListener('click', function() {
            openModal(this.src);
        });

        // Cerrar con click fuera
        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal();
        });

        // Cerrar con Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal.classList.contains('active')) closeModal();
        });

        // Zoom con scroll del mouse
        modal.addEventListener('wheel', function(e) {
            e.preventDefault();
            const delta = e.deltaY > 0 ? -0.15 : 0.15;
            scale = Math.max(0.5, Math.min(4, scale + delta));
            clampPosition();
            updateTransform();
        }, { passive: false });

        // Arrastrar (pan)
        container.addEventListener('mousedown', function(e) {
            if (scale <= 1) return;
            isDragging = true;
            startX = e.clientX - posX;
            startY = e.clientY - posY;
            container.classList.add('dragging');
            e.preventDefault();
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;
            posX = e.clientX - startX;
            posY = e.clientY - startY;
            clampPosition();
            updateTransform();
        });

        document.addEventListener('mouseup', function() {
            isDragging = false;
            container.classList.remove('dragging');
        });

        // Touch: pinch-to-zoom y drag
        container.addEventListener('touchstart', function(e) {
            if (e.touches.length === 2) {
                lastTouchDist = Math.hypot(
                    e.touches[0].clientX - e.touches[1].clientX,
                    e.touches[0].clientY - e.touches[1].clientY
                );
            } else if (e.touches.length === 1 && scale > 1) {
                isDragging = true;
                startX = e.touches[0].clientX - posX;
                startY = e.touches[0].clientY - posY;
            }
        }, { passive: true });

        container.addEventListener('touchmove', function(e) {
            if (e.touches.length === 2) {
                e.preventDefault();
                const dist = Math.hypot(
                    e.touches[0].clientX - e.touches[1].clientX,
                    e.touches[0].clientY - e.touches[1].clientY
                );
                const delta = (dist - lastTouchDist) * 0.01;
                scale = Math.max(0.5, Math.min(4, scale + delta));
                lastTouchDist = dist;
                clampPosition();
                updateTransform();
            } else if (isDragging && e.touches.length === 1) {
                posX = e.touches[0].clientX - startX;
                posY = e.touches[0].clientY - startY;
                clampPosition();
                updateTransform();
            }
        }, { passive: false });

        container.addEventListener('touchend', function() {
            isDragging = false;
            lastTouchDist = 0;
        });
    })();
</script>