<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= obra.nombre %> | Detalle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <%- include('../partials/navbar') %>

    <div class="container py-5">
        <div class="card shadow-lg">
            <div class="row g-0">
                <!-- Columna Imagen -->
                <div class="col-md-6">
                    <img src="<%= obra.foto ? ('/uploads/' + obra.foto) : '/img/default_obra.jpg' %>" class="img-fluid rounded-start w-100 h-100 object-fit-cover" alt="<%= obra.nombre %>">
                </div>
                
                <!-- Columna Datos -->
                <div class="col-md-6">
                    <div class="card-body p-4">
                        <span class="badge bg-info text-dark mb-2"><%= obra.nombre_genero %></span>
                        <h2 class="card-title fw-bold"><%= obra.nombre %></h2>
                        
                        <h4 class="text-muted mb-3">
                            Artista: <a href="/galeria/artista/<%= obra.autor_id %>"><%= obra.nombre_artista %> <%= obra.apellido_artista %></a>
                        </h4>
                        
                        <h1 class="text-success fw-bold mb-4">$<%= parseFloat(obra.precioObra).toLocaleString('en-US') %></h1>

                        <hr>

                        <h5>Características Específicas</h5>
                        <ul class="list-group list-group-flush mb-4">
                            <!-- Datos Generales -->
                            <li class="list-group-item"><strong>Nacionalidad Autor:</strong> <%= obra.nacionalidad %></li>

                            <!-- LÓGICA DE HERENCIA VISUAL (EJS) -->
                            
                            <!-- Si es PINTURA -->
                            <% if (obra.tecnica) { %>
                                <li class="list-group-item"><strong>Técnica:</strong> <%= obra.tecnica %></li>
                                <li class="list-group-item"><strong>Soporte:</strong> <%= obra.soporte %></li>
                            <% } %>

                            <!-- Si es ESCULTURA -->
                            <% if (obra.material) { %>
                                <li class="list-group-item"><strong>Material:</strong> <%= obra.material %></li>
                                <li class="list-group-item"><strong>Peso:</strong> <%= obra.peso %> Kg</li>
                                <li class="list-group-item"><strong>Dimensiones:</strong> <%= obra.largo %>x<%= obra.ancho %>x<%= obra.profundidad %> cm</li>
                            <% } %>

                            <!-- Si es FOTOGRAFÍA -->
                            <% if (obra.tipo_foto) { %>
                                <li class="list-group-item"><strong>Tipo:</strong> <%= obra.tipo_foto %></li>
                                <li class="list-group-item"><strong>Papel:</strong> <%= obra.papel %></li>
                                <li class="list-group-item"><strong>Formato:</strong> <%= obra.formato %></li>
                            <% } %>

                            <!-- Si es CERÁMICA -->
                            <% if (obra.tipoArcilla) { %>
                                <li class="list-group-item"><strong>Arcilla:</strong> <%= obra.tipoArcilla %></li>
                                <li class="list-group-item"><strong>Temperatura:</strong> <%= obra.temperaturaCoccion %> °C</li>
                            <% } %>

                             <!-- Si es ORFEBRERÍA -->
                             <% if (obra.metal) { %>
                                <li class="list-group-item"><strong>Metal:</strong> <%= obra.metal %></li>
                                <li class="list-group-item"><strong>Pureza:</strong> <%= obra.pureza %></li>
                                <li class="list-group-item"><strong>Piedra Preciosa:</strong> <%= obra.piedraPreciosa ? 'Sí' : 'No' %></li>
                            <% } %>
                        </ul>

                        <div class="d-grid gap-2">
                            <!-- Botón de compra: Verificar disponibilidad antes de redirigir -->
                            <button onclick="comprarAhora('<%= obra.nombre %>')" class="btn btn-primary btn-lg">Comprar ahora</button>
                            <a href="/galeria" class="btn btn-outline-secondary">Volver al catálogo</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function comprarAhora(nombre) {
            try {
                // Primero verificar si el usuario está logueado
                const sessionRes = await fetch('/auth/check-session');
                const sessionData = await sessionRes.json();
                if (!sessionData.loggedIn) {
                    // Si no está logueado, redirigir al login
                    window.location.href = '/auth/login';
                    return;
                }

                // Si está logueado, verificar disponibilidad de la obra
                const res = await fetch('/obra/check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ obraNombre: nombre })
                });
                const data = await res.json();
                if (res.ok && data.found && (data.estatus || '').toLowerCase() === 'disponible') {
                    window.location.href = '/pagos/confirmar-reserva?obraNombre=' + encodeURIComponent(nombre);
                } else {
                    alert('La Obra ' + nombre + ' ya está Reservada o ha sido Comprada');
                }
            } catch (err) {
                alert('Error al verificar la disponibilidad de la obra. Intente de nuevo.');
            }
        }
    </script>
</body>
</html>
