<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Importamos Playfair Display para los títulos elegantes -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
        --at-red-soft: rgba(248, 113, 113, 0.15);
        --at-red-border: rgba(248, 113, 113, 0.4);
    }

    .gallery-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 40px 0 80px 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .gallery-title {
        font-weight: 800;
        color: white;
        font-size: 2.8rem;
        letter-spacing: -1.5px;
        margin-bottom: 40px;
    }

    /* FILTROS (ESTILO CRISTAL CARBONO) */
    .filter-sidebar {
        background-color: var(--at-card-bg) !important;
        backdrop-filter: blur(12px);
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 25px;
        position: sticky;
        top: 110px; 
        z-index: 90;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .filter-label {
        display: block;
        color: #94a3b8;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 10px;
    }

    /* ESTILO BARRA DE BÚSQUEDA */
    .search-container {
        position: relative;
        margin-bottom: 25px;
    }

    .search-input {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 12px !important;
        padding: 12px 40px 12px 15px !important;
        width: 100%;
        font-size: 0.9rem;
    }

    .search-input:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 10px var(--at-orange-glow);
        outline: none;
    }

    .search-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--at-orange);
        pointer-events: none;
    }

    .custom-select {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 12px !important;
        padding: 10px !important;
        margin-bottom: 22px;
        cursor: pointer;
    }

    .btn-reset-aesthetic {
        display: block;
        width: 100%;
        padding: 10px;
        background: var(--at-red-soft);
        color: #f87171;
        border: 1.5px dashed var(--at-red-border);
        border-radius: 12px;
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .btn-reset-aesthetic:hover {
        background: rgba(248, 113, 113, 0.25);
        border-style: solid;
        color: #fca5a5;
    }

    /* ANIMACIÓN CASCADA */
    .art-item {
        opacity: 0;
        transform: translateY(30px);
        animation: revealIn 0.8s forwards ease-out;
        animation-delay: var(--delay);
    }

    @keyframes revealIn {
        to { opacity: 1; transform: translateY(0); }
    }

    /* CARD DE OBRA */
    .obra-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 24px;
        padding: 18px;
        height: 100%;
        transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        display: flex;
        flex-direction: column;
    }

    .obra-card:hover {
        transform: translateY(-10px);
        border-color: var(--at-orange) !important; 
        box-shadow: 0 0 25px var(--at-orange-glow); 
    }

    .img-container {
        width: 100%;
        height: 280px;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 18px;
        background: #000;
    }

    .obra-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
        opacity: 0.95;
    }

    .obra-card:hover .obra-img {
        transform: scale(1.08);
        opacity: 1;
    }

    .category-tag {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--at-orange);
        border: 1px solid rgba(249, 115, 22, 0.3);
        padding: 2px 8px;
        border-radius: 4px;
        margin-bottom: 10px;
        background: rgba(249, 115, 22, 0.05);
    }

    .obra-title {
        font-family: 'Playfair Display', serif; 
        font-size: 1.6rem;
        font-weight: 700;
        color: white;
        margin-bottom: 6px;
        line-height: 1.1;
    }

    .obra-artist {
        font-size: 0.85rem;
        color: #94a3b8;
        margin-bottom: 12px;
    }

    .obra-artist a {
        color: var(--at-orange) !important; 
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }
    
    .obra-artist a:hover {
        color: white !important;
        text-shadow: 0 0 8px var(--at-orange);
    }

    .obra-price {
        font-size: 1.6rem;
        font-weight: 800;
        color: white;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

    .btn-atrium-pill {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 12px 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        display: block;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        margin-top: auto;
    }

    .btn-atrium-pill:hover {
        transform: scale(1.02);
        filter: brightness(1.1);
    }
</style>

<div class="gallery-wrapper">
    <div class="container">
        
        <div class="text-start mb-5">
            <h1 class="gallery-title m-0">Galería <span style="color: var(--at-orange)">Atrium</span></h1>
        </div>

        <div class="row g-4">
            <!-- FILTROS -->
            <div class="col-lg-3">
                <aside class="filter-sidebar">
                    <!-- Formulario unificado -->
                    <form action="/galeria" method="GET" id="filterForm">
                        
                        <!-- BARRA DE BÚSQUEDA EN TIEMPO REAL -->
                        <span class="filter-label">Búsqueda Inteligente</span>
                        <div class="search-container">
                            <input type="text" id="realTimeSearch" name="busqueda" class="search-input" placeholder="Nombre u artista..." value="<%= filtros.busqueda || '' %>" autocomplete="off">
                            <span class="search-icon">🔍</span>
                        </div>

                        <span class="filter-label">Disciplina</span>
                        <select name="genero" class="form-select custom-select" onchange="this.form.submit()">
                            <option value="">Todas</option>
                            <% if (locals.generos) { %>
                                <% generos.forEach(g => { %>
                                    <option value="<%= g.Id %>" <%= filtros.genero == g.Id ? 'selected' : '' %>><%= g.nombre %></option>
                                <% }) %>
                            <% } %>
                        </select>

                        <span class="filter-label">Maestro</span>
                        <select name="artista" class="form-select custom-select" onchange="this.form.submit()">
                            <option value="">Todos los artistas</option>
                            <% if (locals.artistas) { %>
                                <% artistas.forEach(a => { %>
                                    <option value="<%= a.id %>" <%= filtros.artista == a.id ? 'selected' : '' %>><%= a.nombre %> <%= a.apellido %></option>
                                <% }) %>
                            <% } %>
                        </select>

                        <span class="filter-label">Inversión</span>
                        <select name="precio" class="form-select custom-select" onchange="this.form.submit()">
                            <option value="">Cualquier precio</option>
                            <option value="menor" <%= filtros.precio == 'menor' ? 'selected' : '' %>>Menor a Mayor</option>
                            <option value="mayor" <%= filtros.precio == 'mayor' ? 'selected' : '' %>>Mayor a Menor</option>
                        </select>

                        <div class="pt-2">
                            <a href="/galeria" class="btn-reset-aesthetic">
                                ✕ Limpiar filtros
                            </a>
                        </div>
                    </form>
                </aside>
            </div>

            <!-- GRILLA DE OBRAS -->
            <div class="col-lg-9">
                <div class="row g-4" id="artGrid">
                    <% if (locals.obras && obras.length > 0) { %>
                        <% obras.forEach((obra, index) => { %>
                            <!-- Añadimos data-search para que el JS sepa qué texto buscar -->
                            <div class="col-md-6 col-xl-4 art-item" 
                                 style="--delay: <%= index * 100 %>ms"
                                 data-search="<%= obra.nombre %> <%= obra.nombre_artista %> <%= obra.apellido_artista %>">
                                <article class="obra-card shadow-lg">
                                    <div class="img-container">
                                        <img src="<%= obra.foto ? ('/uploads/' + obra.foto) : '/img/default_obra.jpg' %>" class="obra-img" alt="<%= obra.nombre %>">
                                    </div>
                                    
                                    <div class="obra-info">
                                        <div class="category-tag"><%= obra.nombre_genero %></div>
                                        <h3 class="obra-title text-truncate text-start"><%= obra.nombre %></h3>
                                        <p class="obra-artist text-truncate text-start">
                                            Por: <a href="/galeria/artista/<%= obra.autor_id %>">
                                                <%= obra.nombre_artista %> <%= obra.apellido_artista %>
                                            </a>
                                        </p>
                                        <div class="obra-price text-start">$<%= parseFloat(obra.precioObra || 0).toLocaleString() %></div>
                                        
                                        <a href="/galeria/detalle/<%= obra.id %>" class="btn-atrium-pill">
                                            Ver Detalles
                                        </a>
                                    </div>
                                </article>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <h4 class="text-white-50 fw-light">No hay resultados.</h4>
                            <a href="/galeria" style="color: var(--at-orange)">Ver todo el catálogo</a>
                        </div>
                    <% } %>
                    <!-- Contenedor para cuando no hay resultados en la búsqueda real -->
                    <div id="noResults" class="col-12 text-center py-5 d-none">
                        <h4 class="text-white-50 fw-light">No se encontraron coincidencias en esta vista.</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('realTimeSearch');
        const artItems = document.querySelectorAll('.art-item');
        const noResults = document.getElementById('noResults');

        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase().trim();
            let hasVisibleItems = false;

            artItems.forEach(item => {
                const searchText = item.getAttribute('data-search').toLowerCase();
                
                if (searchText.includes(term)) {
                    item.style.display = 'block';
                    hasVisibleItems = true;
                } else {
                    item.style.display = 'none';
                }
            });

            // Mostrar mensaje si no hay resultados locales
            if (!hasVisibleItems && term !== "") {
                noResults.classList.remove('d-none');
            } else {
                noResults.classList.add('d-none');
            }
        });
        
        // Evitar que el formulario se envíe al presionar Enter en el buscador 
        // (para que no recargue la página y pierda la fluidez)
        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
            }
        });
    });
</script>

<style>
    @keyframes revealIn { to { opacity: 1; transform: translateY(0); } }
</style>