<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Inventario de Obras</h2>
        <a href="/admin/gestion-obras" class="btn btn-primary">Registrar nueva obra</a>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Obra</th>
                    <th>Artista</th>
                    <th>Género</th>
                    <th>Estatus</th>
                    <th>Precio</th>
                </tr>
            </thead>
            <tbody>
                <% if (obras.length > 0) { %>
                    <% obras.forEach(o => { %>
                        <tr>
                            <td>#<%= o.id %></td>
                            <td><%= o.nombre %></td>
                            <td><%= o.nombre_artista %> <%= o.apellido_artista %></td>
                            <td><%= o.nombre_genero %></td>
                            <td><span class="badge bg-secondary"><%= o.estatus %></span></td>
                            <td>$<%= parseFloat(o.precioObra).toLocaleString('en-US') %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" class="text-center">No hay obras registradas.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
