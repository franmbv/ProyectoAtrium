<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-dark text-white">
            <h4>Revisar Factura</h4>
        </div>
        <div class="card-body">
            <form action="/admin/emitir-factura" method="POST">
                <input type="hidden" name="obra_id" value="<%= obra.id %>">
                <input type="hidden" name="precioObra" value="<%= obra.precioObra %>">
                <input type="hidden" name="porcentajeGanancia" value="<%= obra.porcentajeGanancia %>">
                <input type="hidden" name="comprador_id" value="<%= comprador.id %>">

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h5 class="text-secondary">Detalle de la Obra</h5>
                        <p><strong>Título:</strong> <%= obra.nombre %></p>
                        <p><strong>Precio Base:</strong> $<%= parseFloat(obra.precioObra).toLocaleString('en-US') %></p>
                        <p><strong>% Ganancia Museo:</strong> <%= obra.porcentajeGanancia %>%</p>
                    </div>
                    <div class="col-md-6 border-start">
                        <h5 class="text-secondary">Datos del Comprador</h5>
                        <p><strong>Nombre:</strong> <%= comprador.nombre %> <%= comprador.apellido %></p>
                        <p><strong>Correo:</strong> <%= comprador.gmail %></p>
                    </div>
                </div>

                <hr>

                <h5 class="mb-3 text-secondary">Datos de Envío y Facturación</h5>
                
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">País</label>
                        <input type="text" name="pais" class="form-control" value="Venezuela" readonly>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Estado</label>
                        <select name="estado" class="form-select">
                            <option value="Pendiente" selected>Pendiente</option>
                            <option value="Bolívar">Bolívar</option>
                            <option value="Caracas">Caracas</option>
                            <option value="Anzoátegui">Anzoátegui</option>
                            <option value="Carabobo">Carabobo</option>
                            <option value="Zulia">Zulia</option>
                            <option value="Lara">Lara</option>
                            <option value="Monagas">Monagas</option>
                            </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Ciudad</label>
                        <input type="text" name="ciudad" class="form-control" value="Pendiente" placeholder="Ej: Puerto Ordaz">
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Municipio</label>
                        <input type="text" name="municipio" class="form-control" value="Pendiente" placeholder="Ej: Caroní">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Calle / Avenida / Casa / Edificio</label>
                        <input type="text" name="calle" class="form-control" value="Pendiente" placeholder="Dirección exacta...">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Empresa de Envío (Courier)</label>
                    <select name="empresaEnvio" class="form-select">
                        <option value="Pendiente" selected>Pendiente</option>
                        <option value="DHL">DHL</option>
                        <option value="FedEx">FedEx</option>
                        <option value="MRW">MRW</option>
                        <option value="Zoom">Zoom</option>
                        <option value="Tealca">Tealca</option>
                        <option value="Liberty Express">Liberty Express</option>
                    </select>
                </div>

                <div class="alert alert-info d-flex align-items-center">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <div>
                        El sistema calculará automáticamente el <strong>16% de IVA</strong> y la ganancia del museo sobre el precio base.
                    </div>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100">
                    Aceptar Reserva y Generar Factura
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>