<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4" style="max-width: 1000px;">
    <h2 class="text-white fw-bold mb-4">📊 Reporte de Ventas</h2>

    <form action="/admin/reportes-ventas" method="GET" class="row g-3 mb-4 bg-white p-3 rounded shadow-sm">
        <div class="col-md-4">
            <label class="form-label small fw-bold">Desde</label>
            <input type="date" name="fechaInicio" class="form-control" value="<%= filtros.fechaInicio %>">
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-bold">Hasta</label>
            <input type="date" name="fechaFin" class="form-control" value="<%= filtros.fechaFin %>">
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filtrar Periodo</button>
        </div>
    </form>

    <div class="card shadow border-0 overflow-hidden" style="max-width: 100%;">
        <div class="table-responsive bg-white">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Factura</th>
                        <th>Fecha</th>
                        <th>Obra</th>
                        <th>Ganancia Museo</th>
                        <th>% Museo</th>
                        <th>Total Recaudado</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (ventas.length > 0) { %>
                        <% ventas.forEach(v => { %>
                            <tr>
                                <td class="small fw-bold"><%= v.codigoDeFactura %></td>
                                <td><%= new Date(v.fechaDeVenta).toLocaleDateString() %></td>
                                <td><%= v.nombre_obra %></td>
                                <td class="text-primary">$<%= v.gananciaMuseoDolares %></td>
                                <td><%= v.gananciaMuseoPorcentaje %>%</td>
                                <td class="fw-bold text-success">$<%= v.precioFinalVenta %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" class="p-4">Sin datos en este periodo.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center mt-5 mb-5">
        <a href="/admin/dashboard" class="btn btn-secondary shadow-sm">← Volver al Panel Administrativo</a>
    </div>
</div>

<%- include('../partials/footer') %>