<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     /* Azul Carbono */
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.08);
        --at-green-text: #4ade80;  /* Verde neón para dinero */
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* CARD DE FORMULARIO Y TABLA */
    .admin-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    /* INPUTS ESTILO DARK */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
        /* Hace que el calendario nativo sea oscuro */
        color-scheme: dark; 
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    /* BOTONES */
    .btn-atrium-orange {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        width: 100%;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }
    .btn-atrium-orange:hover { transform: translateY(-3px); filter: brightness(1.1); }

    /* ESTILO DE LA TABLA */
    .inventory-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .table-atrium {
        color: white !important;
        margin-bottom: 0;
    }

    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; /* Letras negras en naranja */
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 18px;
        border: none;
        text-align: center;
    }

    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 18px;
        vertical-align: middle;
    }

    .btn-back-atrium {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-back-atrium:hover { color: white; border-color: white; background: rgba(255,255,255,0.03); }

    .money-highlight {
        color: white !important; /* CAMBIO: Ahora es blanco puro */
        font-weight: 800;
        font-size: 1rem;
    }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1000px;">
        
        <!-- HEADER -->
        <h2 class="admin-title mb-5">📊 Reporte de Ventas</h2>

        <!-- FILTROS -->
        <div class="admin-card mb-5">
            <form action="/admin/reportes-ventas" method="GET" class="row g-4 align-items-end">
                <div class="col-md-4">
                    <label class="form-label-custom">Desde</label>
                    <input type="date" name="fechaInicio" class="form-control input-custom" value="<%= filtros.fechaInicio %>">
                </div>
                <div class="col-md-4">
                    <label class="form-label-custom">Hasta</label>
                    <input type="date" name="fechaFin" class="form-control input-custom" value="<%= filtros.fechaFin %>">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-atrium-orange">Filtrar Periodo</button>
                </div>
            </form>
        </div>

        <!-- TABLA DE VENTAS -->
        <div class="inventory-card">
            <div class="table-responsive">
                <table class="table table-atrium align-middle text-center">
                    <thead>
                        <tr>
                            <th>Factura</th>
                            <th>Fecha</th>
                            <th>Obra</th>
                            <th>Ganancia Museo</th>
                            <th>% Museo</th>
                            <th>Total Recaudado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (ventas.length > 0) { %>
                            <% ventas.forEach(v => { %>
                                <tr>
                                    <td class="text-white-50 small font-monospace"><%= v.codigoDeFactura %></td>
                                    
                                    <!-- FECHA BLANCA -->
                                    <td class="text-white fw-bold"><%= new Date(v.fechaDeVenta).toLocaleDateString() %></td>
                                    
                                    <!-- OBRA BLANCA -->
                                    <td class="text-white fw-bold"><%= v.nombre_obra %></td>
                                    
                                    <!-- Ganancia en gris/azul claro -->
                                    <td style="color: #94a3b8">$<%= v.gananciaMuseoDolares %></td>
                                    
                                    <!-- Badge de porcentaje -->
                                    <td><span class="badge bg-dark border border-secondary text-white-50"><%= v.gananciaMuseoPorcentaje %>%</span></td>
                                    
                                    <!-- TOTAL RECAUDADO EN BLANCO -->
                                    <td class="money-highlight">$<%= v.precioFinalVenta %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6" class="p-5 text-white-50 small">No hay datos de ventas en este periodo.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- REGRESO -->
        <div class="text-start mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-back-atrium shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>