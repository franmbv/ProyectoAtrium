<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     /* Azul Carbono */
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
        --at-red-soft: rgba(248, 113, 113, 0.15);
        --at-red-border: rgba(248, 113, 113, 0.4);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* CARD DE FILTROS UNIFICADA EN UNA LÍNEA */
    .filter-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    /* INPUTS ESTILO DARK */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 11px !important;
        transition: all 0.3s;
        color-scheme: dark; 
    }

    /* MEJORA DE VISIBILIDAD DEL PLACEHOLDER - ACTUALIZADO */
    .input-custom::placeholder {
        color: #cbd5e1 !important; /* Gris azulado muy claro para mayor distinción */
        opacity: 1; 
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    /* BOTÓN LIMPIAR */
    .btn-reset-aesthetic {
        display: block;
        width: 100%;
        padding: 11px;
        background: var(--at-red-soft);
        color: #f87171;
        border: 1.5px dashed var(--at-red-border);
        border-radius: 10px;
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .btn-reset-aesthetic:hover {
        background: rgba(248, 113, 113, 0.25);
        border-style: solid;
        color: #fca5a5;
    }

    /* TABLA */
    .table-container-custom {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .table-atrium { color: white !important; margin-bottom: 0; }

    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; 
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 18px;
        border: none;
        text-align: center;
    }

    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 18px;
        vertical-align: middle;
        text-align: center;
    }

    .status-badge-active {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #4ade80;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        background: rgba(74, 222, 128, 0.1);
        padding: 4px 12px;
        border-radius: 50px;
        border: 1px solid rgba(74, 222, 128, 0.2);
    }

    .btn-back-atrium {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 40px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
    }
    .btn-back-atrium:hover { color: white; border-color: white; background: rgba(255,255,255,0.03); }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1100px;">
        
        <h2 class="admin-title mb-5 text-start"><span role="img">💳</span>Usuarios con Membresía</h2>

        <!-- FILTROS EN UNA SOLA LÍNEA AUTOMÁTICOS -->
        <div class="filter-card mb-5">
            <form action="/admin/reportes-membresia" method="GET" id="memberFilterForm" class="row g-3 align-items-end">
                
                <!-- BÚSQUEDA INTELIGENTE -->
                <div class="col-md-4">
                    <label class="form-label-custom">Búsqueda de Comprador</label>
                    <input type="text" id="memberSearch" class="form-control input-custom" placeholder="Nombre, apellido o cédula..." autocomplete="off">
                </div>
                
                <!-- FECHA DESDE -->
                <div class="col-md-3">
                    <label class="form-label-custom">Desde:</label>
                    <input type="date" name="fechaInicio" class="form-control input-custom" value="<%= filtros?.fechaInicio %>" onchange="this.form.submit()">
                </div>

                <!-- FECHA HASTA -->
                <div class="col-md-3">
                    <label class="form-label-custom">Hasta:</label>
                    <input type="date" name="fechaFin" class="form-control input-custom" value="<%= filtros?.fechaFin %>" onchange="this.form.submit()">
                </div>

                <!-- LIMPIAR -->
                <div class="col-md-2">
                    <a href="/admin/reportes-membresia" class="btn-reset-aesthetic">✕ Limpiar</a>
                </div>
            </form>
        </div>

        <!-- LISTADO -->
        <div class="table-container-custom">
            <div class="table-responsive">
                <table class="table table-atrium align-middle">
                    <thead>
                        <tr>
                            <th>Comprador</th>
                            <th>Cédula</th>
                            <th>Fecha de Pago</th>
                            <th>Estatus</th>
                        </tr>
                    </thead>
                    <tbody id="membersTableBody">
                        <% if (typeof membresias !== 'undefined' && membresias.length > 0) { %>
                            <% membresias.forEach(m => { %>
                                <tr class="member-row" data-search="<%= m.nombre.toLowerCase() %> <%= m.apellido.toLowerCase() %> <%= m.cedula.toLowerCase() %>">
                                    <td class="fw-bold text-white"><%= m.nombre %> <%= m.apellido %></td>
                                    <td style="color: #94a3b8;"><%= m.cedula %></td>
                                    <td class="fw-bold text-white"><%= m.fechaPago ? new Date(m.fechaPago).toLocaleDateString('es-ES', { timeZone: 'UTC' }) : 'N/N' %></td>
                                    <td>
                                        <div class="status-badge-active">
                                            <span style="width: 8px; height: 8px; background: #4ade80; border-radius: 50%; box-shadow: 0 0 8px #4ade80;"></span>
                                            Activo
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr id="emptyMsg"><td colspan="4" class="p-5 text-white-50 text-center">No se encontraron registros para este rango de fechas.</td></tr>
                        <% } %>
                        <tr id="noResults" style="display: none;"><td colspan="4" class="p-5 text-warning opacity-75 text-center">No hay coincidencias en la vista actual.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- REGRESO -->
        <div class="text-start mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-back-atrium shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('memberSearch');
        const rows = document.querySelectorAll('.member-row');
        const noResults = document.getElementById('noResults');
        const emptyMsg = document.getElementById('emptyMsg');

        searchInput.addEventListener('input', () => {
            const term = searchInput.value.toLowerCase().trim();
            let hasMatches = false;

            rows.forEach(row => {
                const searchData = row.getAttribute('data-search');
                if (searchData.includes(term)) {
                    row.style.display = '';
                    hasMatches = true;
                } else {
                    row.style.display = 'none';
                }
            });

            if (term !== "") {
                if (emptyMsg) emptyMsg.style.display = 'none';
                noResults.style.display = hasMatches ? 'none' : '';
            } else {
                if (emptyMsg) emptyMsg.style.display = '';
                noResults.style.display = 'none';
            }
        });

        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') e.preventDefault();
        });
    });
</script>