<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     /* Azul Carbono */
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* CARD DE FILTROS */
    .filter-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    /* INPUTS ESTILO DARK */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
        color-scheme: dark; /* Hace que el calendario sea oscuro */
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    /* BOTÓN FILTRAR */
    .btn-atrium-filter {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        width: 100%;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }
    .btn-atrium-filter:hover { transform: translateY(-3px); filter: brightness(1.1); }

    /* ESTILO DE LA TABLA (ENCABEZADO NARANJA / LETRAS NEGRAS) */
    .table-container-custom {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .table-atrium {
        color: white !important;
        margin-bottom: 0;
    }

    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; 
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 18px;
        border: none;
        text-align: center;
    }

    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 18px;
        vertical-align: middle;
        text-align: center;
    }

    /* Badge de Estatus Neón */
    .status-badge-active {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #4ade80;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        background: rgba(74, 222, 128, 0.1);
        padding: 4px 12px;
        border-radius: 50px;
        border: 1px solid rgba(74, 222, 128, 0.2);
    }

    .btn-back-atrium {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 40px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
    }
    .btn-back-atrium:hover { color: white; border-color: white; background: rgba(255,255,255,0.03); }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1000px;">
        
        <h2 class="admin-title mb-5 text-start">💳 Usuarios con Membresía</h2>

        <!-- FILTROS (RECUADRO AZULADO) -->
        <div class="filter-card mb-5">
            <form action="/admin/reportes-membresia" method="GET" class="row g-4 align-items-end">
                <div class="col-md-4 text-start">
                    <label class="form-label-custom">Desde:</label>
                    <input type="date" name="fechaInicio" class="form-control input-custom" value="<%= filtros?.fechaInicio %>">
                </div>
                <div class="col-md-4 text-start">
                    <label class="form-label-custom">Hasta:</label>
                    <input type="date" name="fechaFin" class="form-control input-custom" value="<%= filtros?.fechaFin %>">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-atrium-filter">Filtrar Reporte</button>
                </div>
            </form>
        </div>

        <!-- LISTADO (TABLA ESTILO ATRIUM) -->
        <div class="table-container-custom">
            <div class="table-responsive">
                <table class="table table-atrium align-middle">
                    <thead>
                        <tr>
                            <th>Comprador</th>
                            <th>Cédula</th>
                            <th>Fecha de Pago</th>
                            <th>Estatus</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof membresias !== 'undefined' && membresias.length > 0) { %>
                            <% membresias.forEach(m => { %>
                                <tr>
                                    <td class="fw-bold text-white"><%= m.nombre %> <%= m.apellido %></td>
                                    <td style="color: #94a3b8;"><%= m.cedula %></td>
                                    <!-- FECHA DE PAGO AHORA ES BLANCA -->
                                    <td class="fw-bold text-white"><%= m.fechaPago ? new Date(m.fechaPago).toLocaleDateString('es-ES', { timeZone: 'UTC' }) : 'N/A' %></td>
                                    <td>
                                        <div class="status-badge-active">
                                            <span style="width: 8px; height: 8px; background: #4ade80; border-radius: 50%; box-shadow: 0 0 8px #4ade80;"></span>
                                            Activo
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" class="p-5 text-white-50">No se encontraron registros en este periodo.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- REGRESO -->
        <div class="text-start mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-back-atrium shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>