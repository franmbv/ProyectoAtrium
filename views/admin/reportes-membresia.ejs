<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4" style="max-width: 1000px;">
    
    <h2 class="text-white fw-bold mb-4 text-center">💳 Usuarios con Membresía</h2>

    <!-- Formulario de filtros (Mide 1000px de ancho) -->
    <form action="/admin/reportes-membresia" method="GET" class="row g-3 mb-4 bg-white p-3 rounded border shadow-sm mx-0">
        <div class="col-md-4">
            <label class="form-label small fw-bold text-dark">Desde:</label>
            <input type="date" name="fechaInicio" class="form-control" value="<%= filtros?.fechaInicio %>">
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-bold text-dark">Hasta:</label>
            <input type="date" name="fechaFin" class="form-control" value="<%= filtros?.fechaFin %>">
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filtrar Reporte</button>
        </div>
    </form>

    <!-- Listado (Forzamos que mida el 100% para ignorar los 680px del CSS global) -->
    <div class="card shadow border-0 overflow-hidden mx-auto" style="max-width: 100% !important;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Comprador</th>
                        <th>Cédula</th>
                        <th>Fecha de Pago</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof membresias !== 'undefined' && membresias.length > 0) { %>
                        <% membresias.forEach(m => { %>
                            <tr>
                                <td class="text-muted small">#<%= m.Id %></td>
                                <td class="fw-bold"><%= m.nombre %> <%= m.apellido %></td>
                                <td><%= m.cedula %></td>
                                <td><%= m.fechaPago ? new Date(m.fechaPago).toLocaleDateString('es-ES', { timeZone: 'UTC' }) : 'N/A' %></td>
                                <td><span class="badge bg-success">Activo</span></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" class="p-4 text-dark">No se encontraron registros.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Botón de regreso -->
    <div class="text-center mt-5 mb-5">
        <a href="/admin/dashboard" class="btn btn-secondary shadow-sm">← Volver al Panel Administrativo</a>
    </div>
</div>

<%- include('../partials/footer') %>