<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4">
    <h2>Registro de Nueva Obra</h2>
    <form action="/admin/guardar-obra" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Nombre de la Obra</label>
                <input type="text" name="nombre" class="form-control" required>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Género</label>
                <select name="genero_id" class="form-select" required>
                    <option value="">Seleccionar</option>
                    <% generos.forEach(g => { %>
                        <option value="<%= g.Id %>"><%= g.nombre %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Artista</label>
                <select name="autor_id" class="form-select" required>
                    <option value="">Seleccionar</option>
                    <% artistas.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.nombre %> <%= a.apellido %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">Precio Base ($)</label>
                <input type="number" name="precioObra" class="form-control" required>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">% Ganancia Museo</label>
                <input type="number" name="porcentajeGanancia" min="5" max="10" class="form-control" placeholder="5-10" required>
            </div>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Foto de la Obra (Multer)</label>
            <input type="file" name="foto" class="form-control" accept="image/*" required>
        </div>

        <button type="submit" class="btn btn-primary">Cargar al Catálogo</button>
    </form>
</div>

<%- include('../partials/footer') %>