<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    .form-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 45px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 10px var(--at-orange-glow) !important;
        outline: none;
    }

    #wrapper-detalles-tecnicos {
        border: 1px dashed var(--at-orange);
        background: rgba(249, 115, 22, 0.03);
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
    }

    .tech-header {
        color: var(--at-orange) !important;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 20px;
        display: block;
    }

    .btn-atrium-publish {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 14px 40px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(249, 115, 22, 0.2);
        cursor: pointer;
    }

    .btn-atrium-publish:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 25px var(--at-orange-glow) !important;
    }

    .btn-atrium-back {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 10px 25px;
        font-weight: 600;
        text-decoration: none;
    }

    select option {
        background-color: #0d1117;
        color: white;
    }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1000px;">
        
        <div class="form-card">
            <h2 class="admin-title mb-5"><span role="img">🎨</span>Registro de Obras</h2>
            
            <form action="/admin/guardar-obra" method="POST" enctype="multipart/form-data">
                <!-- Fila 1: Campos Base de la Obra -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Nombre de la Obra</label>
                        <input type="text" name="nombre" class="form-control input-custom" required placeholder="Ej: Obra de Arte">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-custom">Género / Disciplina</label>
                        <select name="genero_id" class="form-select input-custom" id="genero_id" required>
                            <option value="">Seleccionar Género</option>
                            <% generos.forEach(g => { %>
                                <option value="<%= g.id %>"><%= g.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-custom">Artista</label>
                        <select name="autor_id" class="form-select input-custom" required>
                            <option value="">Seleccionar Artista</option>
                            <% artistas.forEach(a => { %>
                                <option value="<%= a.id %>"><%= a.nombre %> <%= a.apellido %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <!-- Fila 2: Precios e Impuestos -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Precio Base ($)</label>
                        <input type="number" name="precioObra" class="form-control input-custom" required placeholder="0.00" min="0" step="0.01">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">% Ganancia Museo</label>
                        <input type="number" name="porcentajeGanancia" min="5" max="10" step="0.01" class="form-control input-custom" placeholder="De 5% a 10%" required>
                    </div>
                </div>
                
                <!-- Fila 3: Carga de Imagen -->
                <div class="mb-5">
                    <label class="form-label-custom">Fotografía Digital</label>
                    <input type="file" name="foto" class="form-control input-custom" accept="image/*" required style="padding: 8px !important;">
                </div>

                <!-- CONTENEDOR TÉCNICO DINÁMICO AUTO-RENDERIZADO -->
                <div id="wrapper-detalles-tecnicos" style="display: none;">
                    <span class="tech-header">Atributos del Género (MongoDB Schema)</span>
                    <div id="dynamic-fields-container" class="row g-3">
                        <!-- Campos polimórficos inyectados vía AJAX por JS -->
                    </div>
                </div>

                <div class="text-end pt-3">
                    <button type="submit" class="btn btn-atrium-publish">Publicar en Atrium</button>
                </div>
            </form>
        </div>

        <div class="text-center mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-atrium-back shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const generoSelect = document.getElementById('genero_id');
        const technicalWrapper = document.getElementById('wrapper-detalles-tecnicos');
        const dynamicContainer = document.getElementById('dynamic-fields-container');

        // Mapeo amigable de nombres de campos técnicos
        const labelTranslate = {
            tecnica: "Técnica Artística",
            soporte: "Soporte Físico",
            material: "Material Utilizado",
            peso: "Peso de la Obra (Kg)",
            largo: "Largo (cm)",
            ancho: "Ancho (cm)",
            profundidad: "Profundidad (cm)",
            tipo_foto: "Tipo de Fotografía",
            papel: "Papel de Impresión",
            formato: "Formato / Proporción",
            tipoArcilla: "Tipo de Arcilla",
            temperaturaCoccion: "Temperatura de Cocción (°C)",
            tipoEsmalte: "Tipo de Esmalte",
            metal: "Metal Base",
            pureza: "Pureza del Metal",
            piedraPreciosa: "Contiene Piedras Preciosas"
        };

        generoSelect.addEventListener('change', async (e) => {
            const generoId = e.target.value;
            
            if (!generoId) {
                technicalWrapper.style.display = 'none';
                dynamicContainer.innerHTML = '';
                return;
            }

            try {
                // Petición AJAX para obtener el esquema de la categoría en MongoDB
                const res = await fetch(`/admin/categorias/especificaciones/${generoId}`);
                if (!res.ok) throw new Error("No se pudo obtener la definición de la categoría");
                const data = await res.json();

                dynamicContainer.innerHTML = '';

                if (data && data.detalles && Object.keys(data.detalles).length > 0) {
                    technicalWrapper.style.display = 'block';

                    Object.entries(data.detalles).forEach(([campo, tipo]) => {
                        const col = document.createElement('div');
                        col.className = 'col-md-6 mb-3';

                        const friendlyLabel = labelTranslate[campo] || campo.charAt(0).toUpperCase() + campo.slice(1);
                        let inputHTML = '';

                        // Renderización del control HTML basado en su tipo de datos NoSQL
                        if (tipo === 'Boolean') {
                            inputHTML = `
                                <label class="form-label-custom">${friendlyLabel}</label>
                                <select name="${campo}" class="form-select input-custom" required>
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            `;
                        } else if (tipo === 'Integer') {
                            inputHTML = `
                                <label class="form-label-custom">${friendlyLabel}</label>
                                <input type="number" step="1" name="${campo}" class="form-control input-custom" placeholder="Ej: 10" required min="0">
                            `;
                        } else if (tipo === 'Decimal') {
                            inputHTML = `
                                <label class="form-label-custom">${friendlyLabel}</label>
                                <input type="number" step="0.01" name="${campo}" class="form-control input-custom" placeholder="Ej: 12.50" required min="0">
                            `;
                        } else { // String / Texto
                            inputHTML = `
                                <label class="form-label-custom">${friendlyLabel}</label>
                                <input type="text" name="${campo}" class="form-control input-custom" placeholder="Escriba el detalle..." required>
                            `;
                        }

                        col.innerHTML = inputHTML;
                        dynamicContainer.appendChild(col);
                    });
                } else {
                    technicalWrapper.style.display = 'none';
                }
            } catch (err) {
                console.error("Fallo de renderizado dinámico AJAX:", err);
                technicalWrapper.style.display = 'none';
            }
        });
    });
</script>

<%- include('../partials/footer') %>