<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4">
    <h2 class="text-white fw-bold mb-4 text-center">Facturas por comprador</h2>

    <form action="/admin/facturas" method="GET" class="row g-3 mb-4 bg-white p-3 rounded shadow-sm">
        <div class="col-md-4">
            <label class="form-label small fw-bold">Nombre del comprador</label>
            <input type="text" name="nombre" class="form-control" value="<%= filtros ? filtros.nombre : '' %>" placeholder="Ej: Ana Perez">
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold">Desde</label>
            <input type="date" name="fechaInicio" class="form-control" value="<%= filtros ? filtros.fechaInicio : '' %>">
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold">Hasta</label>
            <input type="date" name="fechaFin" class="form-control" value="<%= filtros ? filtros.fechaFin : '' %>">
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>
    </form>

    <div class="row justify-content-center">
        <div class="col-12" style="max-width: 1100px;">
            <% if (grupos.length > 0) { %>
                <% grupos.forEach(g => { %>
                    <div class="card shadow border-0 overflow-hidden mb-4">
                        <div class="card-header bg-dark text-white">
                            <strong><%= g.comprador || 'Comprador' %></strong>
                        </div>
                        <div class="table-responsive bg-white">
                            <table class="table table-hover align-middle mb-0 text-center">
                                <thead class="table-light">
                                    <tr>
                                        <th>Factura</th>
                                        <th>Fecha</th>
                                        <th>Obra</th>
                                        <th>Total</th>
                                        <th>Accion</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (g.facturas.length > 0) { %>
                                        <% g.facturas.forEach(f => { %>
                                            <tr>
                                                <td class="small fw-bold"><%= f.codigoDeFactura %></td>
                                                <td><%= new Date(f.fechaDeVenta).toLocaleDateString() %></td>
                                                <td><%= f.nombre_obra %></td>
                                                <td class="fw-bold text-success">$<%= parseFloat(f.precioFinalVenta).toLocaleString('en-US') %></td>
                                                <td>
                                                    <a href="/admin/facturas/<%= f.id %>" class="btn btn-outline-dark btn-sm">Ver detalle</a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="p-4">No hay facturas registradas.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="card shadow border-0">
                    <div class="card-body text-center">No hay facturas registradas.</div>
                </div>
            <% } %>
        </div>
    </div>

    <div class="text-center mt-5 mb-5">
        <a href="/admin/dashboard" class="btn btn-secondary shadow-sm">← Volver al Panel Administrativo</a>
    </div>
</div>

<%- include('../partials/footer') %>
