<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-yellow-soft: rgba(251, 191, 36, 0.12); 
        --at-yellow-text: #fcd34d;
        --at-red-soft: rgba(239, 68, 68, 0.12);    
        --at-red-text: #fca5a5;
        --at-green-soft: rgba(34, 197, 94, 0.12); 
        --at-green-text: #4ade80; 
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* BARRA DE FILTRO INTELIGENTE */
    .smart-filter-bar {
        background-color: var(--at-card-bg);
        border: 1px solid var(--at-border);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .admin-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    /* Botón examinar en Gris Original */
    .input-custom::file-selector-button {
        background-color: #6c757d; 
        color: white;
        border: none;
        border-right: 1px solid var(--at-border);
        padding: 0 20px;
        margin-right: 15px;
        height: 46px; 
        border-radius: 9px 0 0 9px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-color 0.3s;
    }

    .input-custom::file-selector-button:hover {
        background-color: #5a6268; 
    }

    .btn-atrium-orange {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }
    .btn-atrium-orange:hover { transform: translateY(-3px); filter: brightness(1.1); box-shadow: 0 15px 30px var(--at-orange-glow); }

    .btn-clear-filters {
        background-color: rgba(255, 255, 255, 0.05) !important;
        color: #94a3b8 !important;
        border: 1.5px dashed var(--at-border) !important;
        font-weight: 600;
        border-radius: 10px;
        padding: 10px 20px;
        transition: all 0.3s;
    }
    .btn-clear-filters:hover {
        background-color: rgba(239, 68, 68, 0.1) !important;
        color: #fca5a5 !important;
        border-color: #ef4444 !important;
        border-style: solid;
    }

    /* TABLA */
    .table-atrium { color: white !important; margin-bottom: 0; }
    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; 
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 18px;
        border: none;
    }
    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 18px;
        vertical-align: middle;
    }

    /* ESTILOS DE BOTONES "SOFT" PARA ACCIONES */
    .btn-edit-soft {
        background-color: var(--at-yellow-soft) !important;
        color: var(--at-yellow-text) !important;
        border: 1px solid rgba(251, 191, 36, 0.2) !important;
        font-weight: 700;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.75rem;
        text-decoration: none;
    }
    .btn-delete-soft {
        background-color: var(--at-red-soft) !important;
        color: var(--at-red-text) !important;
        border: 1px solid rgba(239, 68, 68, 0.2) !important;
        font-weight: 700;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.75rem;
        text-decoration: none; 
    }
    .btn-activate-soft {
        background-color: var(--at-green-soft) !important;
        color: var(--at-green-text) !important;
        border: 1px solid rgba(34, 197, 94, 0.2) !important;
        font-weight: 700;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.75rem;
        text-decoration: none;
    }

    .status-indicator-text {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; }

    .st-active { color: var(--at-green-text); }
    .st-active .status-dot { background-color: var(--at-green-text); box-shadow: 0 0 8px var(--at-green-text); }

    .st-inactive { color: var(--at-red-text); }
    .st-inactive .status-dot { background-color: var(--at-red-text); box-shadow: 0 0 8px var(--at-red-text); }

    .btn-back-atrium {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-back-atrium:hover { color: white; border-color: white; }

    .img-artist-thumb {
        width: 50px; height: 50px; object-fit: cover; border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.1);
    }

    .input-custom::placeholder {
        color: #cbd5e1 !important;
        opacity: 1;
    }

    /* SISTEMA DE PUNTOS DE PAGINACIÓN MODERNOS */
    .modern-dots-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-top: 35px;
    }

    .modern-dot {
        width: 14px;
        height: 14px;
        background: #334155;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        color: transparent;
        font-size: 0.65rem;
        font-weight: 900;
        transition: 0.3s;
    }
    .modern-dot.active { background: var(--at-orange); width: 24px; border-radius: 10px; }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1000px;">
        
        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="admin-title m-0"><span role="img">👨‍🎨</span>Gestión de Artistas</h2>
            <button class="btn btn-atrium-orange shadow-lg" type="button" data-bs-toggle="collapse" data-bs-target="#formArtista">
                + AGREGAR ARTISTA
            </button>
        </div>

        <!-- FORMULARIO DE REGISTRO COLAPSABLE -->
        <div class="collapse mb-5" id="formArtista">
            <div class="admin-card">
                <h4 class="text-white mb-4 fw-bold">Registrar Nuevo Maestro</h4>
                
                <form action="/admin/guardar-artista" method="POST" enctype="multipart/form-data" class="row g-4">
                    <!-- Fila 1: Datos de Identidad -->
                    <div class="col-md-6">
                        <label class="form-label-custom">Nombre</label>
                        <input type="text" name="nombre" id="inputNombre" class="form-control input-custom" required placeholder="Ej: Hayao" onblur="validarExistenciaArtista()">
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom">Apellido</label>
                        <input type="text" name="apellido" id="inputApellido" class="form-control input-custom" placeholder="Ej: Miyazaki" onblur="validarExistenciaArtista()">
                    </div>

                    <!-- BOTÓN DINÁMICO DE AUTOCOMPLETADO (Alineado estrictamente a la izquierda) -->
                    <div class="col-12 text-start d-none" id="ai-autocomplete-container">
                        <button type="button" class="btn btn-sm py-2 px-4 border border-warning" style="background: rgba(249, 115, 22, 0.1); color: var(--at-orange); border-radius: 50px; font-weight: 800;" onclick="ejecutarAutocompletadoCompleto()">
                            ✨ Artista Real Identificado: ¿Autocompletar Perfil completo?
                        </button>
                    </div>
                    
                    <div class="col-md-4">
                        <label class="form-label-custom">Nacionalidad</label>
                        <input type="text" name="nacionalidad" id="inputNacionalidad" class="form-control input-custom" required placeholder="Ej: Japonesa">
                    </div>
                    
                    <div class="col-md-4">
                        <label class="form-label-custom">Nacimiento</label>
                        <input type="date" name="fechaNac" id="inputFechaNac" class="form-control input-custom" style="color-scheme: dark;">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label-custom">Fallecimiento</label>
                        <input type="date" name="fechaFal" id="inputFechaFal" class="form-control input-custom" style="color-scheme: dark;">
                    </div>
                    
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label-custom m-0">Biografía</label>
                            <!-- Botón dinámico exclusivo: Solo se muestra si el artista NO es real/reconocido para inventar su biografía -->
                            <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3" id="btn-biografia-ia" onclick="autogenerarSoloBiografia()">✨ Autogenerar Biografía</button>
                        </div>
                        <textarea name="biografia" id="biografia" class="form-control input-custom" rows="3" placeholder="Escriba o autogenere la reseña..."></textarea>
                    </div>
                    
                    <div class="col-md-12">
                        <label class="form-label-custom">Fotografía</label>
                        <input type="file" name="foto" class="form-control input-custom" accept="image/*" style="padding: 8px !important;">
                    </div>
                    
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-atrium-orange px-5">Guardar Artista</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- BARRA DE BÚSQUEDA INTELIGENTE -->
        <div class="smart-filter-bar">
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="small fw-bold text-white-50 mb-2 d-block">BÚSQUEDA CRUZADA (MAESTROS U OBRAS)</label>
                    <input type="text" id="artistSearch" class="form-control input-custom" placeholder="Buscar por nombre, nacionalidad u obras del autor...">
                </div>
                <div class="col-md-4">
                    <button type="button" id="btnClearArtistFilters" class="btn btn-clear-filters w-100">
                        ✕ Limpiar Filtro
                    </button>
                </div>
            </div>
        </div>

        <!-- LISTADO DE ARTISTAS (Columna Obras Relacionadas eliminada físicamente) -->
        <div class="admin-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-atrium align-middle text-center" id="artistsTable">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Perfil</th>
                            <th>Nombre Completo</th>
                            <th>Nacionalidad</th>
                            <th>Estado</th> 
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="artistTableBody">
                        <% artistas.forEach(a => { %>
                            <!-- Atributos de búsqueda cruzada ocultos (data-obras) para buscar por obras por debajo sin mostrarlas en la tabla -->
                            <tr class="artist-row" 
                                data-name="<%= a.nombre.toLowerCase() %> <%= a.apellido ? a.apellido.toLowerCase() : '' %>"
                                data-nat="<%= a.nacionalidad ? a.nacionalidad.toLowerCase() : '' %>"
                                data-obras="<%= (typeof a.obras_asociadas !== 'undefined' && a.obras_asociadas) ? a.obras_asociadas.toLowerCase() : '' %>">
                                <td>
                                    <% if(a.fotografia) { %>
                                        <img src="<%= (a.fotografia && a.fotografia.startsWith('http')) ? a.fotografia : ('/uploads/' + (a.fotografia || 'user.png')) %>" class="img-artist-thumb" alt="Foto">
                                    <% } else { %>
                                        <div class="rounded-circle bg-dark border border-secondary d-inline-flex align-items-center justify-content-center" style="width:50px; height:50px">👤</div>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="fw-bold text-white"><%= a.nombre %> <%= a.apellido %></div>
                                    <small class="text-white-50">ID: #<%= a.id %></small>
                                </td>
                                <td>
                                    <span class="badge bg-dark border border-secondary text-white-50 px-3 py-2"><%= a.nacionalidad %></span>
                                </td>
                                <td> 
                                    <% if (a.estado === 'Activo') { %>
                                        <div class="status-indicator-text st-active">
                                            <span class="status-dot"></span> Activo
                                        </div>
                                    <% } else { %>
                                        <div class="status-indicator-text st-inactive">
                                            <span class="status-dot"></span> Inactivo
                                        </div>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a href="/admin/editar-artista/<%= a.id %>" class="btn-edit-soft">Editar</a>
                                        <% if (a.estado === 'Activo') { %>
                                            <a href="/admin/eliminar-artista/<%= a.id %>" class="btn-delete-soft" onclick="return confirm('¿Inactivar artista?')">Inactivar</a>
                                        <% } else { %>
                                            <a href="/admin/activar-artista/<%= a.id %>" class="btn-activate-soft">Activar</a>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <tr id="noResultsRow" style="display: none;">
                            <td colspan="5" class="p-5 text-warning opacity-75">No hay coincidencia de maestros ni obras asociadas en este listado.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PAGINACIÓN -->
        <div class="modern-dots-container" id="paginationDots"></div>

        <!-- REGRESO -->
        <div class="text-start mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-back-atrium shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
    // Variable global para almacenar el perfil detectado preventivamente por la IA
    let perfilDetectado = null;

    document.addEventListener('DOMContentLoaded', () => {
        const itemsPerPage = 10; 
        let currentPage = 1;
        let filteredRows = [];

        const rows = Array.from(document.querySelectorAll('.artist-row'));
        const paginationDotsContainer = document.getElementById('paginationDots');

        function showPage(page) {
            currentPage = page;
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;

            rows.forEach(r => r.style.display = 'none');
            filteredRows.slice(start, end).forEach(r => {
                r.style.display = '';
            });

            renderDots();
        }

        function renderDots() {
            paginationDotsContainer.innerHTML = '';
            const totalPages = Math.ceil(filteredRows.length / itemsPerPage);

            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                const dot = document.createElement('div');
                dot.className = `modern-dot ${i === currentPage ? 'active' : ''}`;
                dot.innerText = i; 
                dot.addEventListener('click', () => showPage(i));
                paginationDotsContainer.appendChild(dot);
            }
        }

        const searchInput = document.getElementById('artistSearch');
        const btnClear = document.getElementById('btnClearArtistFilters');
        const noResultsRow = document.getElementById('noResultsRow');

        function filterArtists() {
            const term = searchInput.value.toLowerCase().trim();
            
            if (term === "") {
                filteredRows = rows;
                noResultsRow.style.display = 'none';
            } else {
                filteredRows = rows.filter(row => {
                    const name = row.getAttribute('data-name') || '';
                    const nat = row.getAttribute('data-nat') || '';
                    const obras = row.getAttribute('data-obras') || '';
                    return name.includes(term) || nat.includes(term) || obras.includes(term);
                });
                noResultsRow.style.display = filteredRows.length === 0 ? '' : 'none';
            }
            showPage(1);
        }

        if(searchInput) {
            searchInput.addEventListener('input', filterArtists);
        }

        if(btnClear) {
            btnClear.addEventListener('click', () => {
                searchInput.value = '';
                filterArtists();
            });
        }

        filteredRows = rows;
        showPage(1);
    });

    // 1. SISTEMA PREVENTIVO DE VERIFICACIÓN DE EXISTENCIA EN TIEMPO REAL
    async function validarExistenciaArtista() {
        const nombre = document.getElementById('inputNombre').value.trim();
        const apellido = document.getElementById('inputApellido').value.trim();
        
        const autocompleteContainer = document.getElementById('ai-autocomplete-container');
        const btnBiografiaIa = document.getElementById('btn-biografia-ia');

        if (!nombre) {
            autocompleteContainer.classList.add('d-none');
            btnBiografiaIa.classList.remove('d-none');
            perfilDetectado = null;
            return;
        }

        try {
            const res = await fetch('/admin/artistas/generar-biografia', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, apellido })
            });
            const data = await res.json();

            if (data.success && data.profile) {
                perfilDetectado = data.profile;

                // Mutuamente excluyente: Si la IA confirma que existe un personaje real
                if (perfilDetectado.existe) {
                    autocompleteContainer.classList.remove('d-none'); // Muestra autocompletado arriba
                    btnBiografiaIa.classList.add('d-none');          // Oculta generador solo biografía
                } else {
                    autocompleteContainer.classList.add('d-none');
                    btnBiografiaIa.classList.remove('d-none');
                }
            }
        } catch (e) {
            console.error("Fallo de red en validación previa de IA:", e);
        }
    }

    // 2. EJECUTAR EL AUTOCOMPLETADO ESTRUCTURADO (Aparece solo si el artista existe)
    function ejecutarAutocompletadoCompleto() {
        if (!perfilDetectado) return;

        const nacionalidadInput = document.getElementById('inputNacionalidad');
        const nacimientoInput = document.getElementById('inputFechaNac');
        const fallecimientoInput = document.getElementById('inputFechaFal');
        const biografiaInput = document.getElementById('biografia');

        if (nacionalidadInput && perfilDetectado.nacionalidad) {
            nacionalidadInput.value = perfilDetectado.nacionalidad;
        }
        if (nacimientoInput && perfilDetectado.fechaNac) {
            nacimientoInput.value = perfilDetectado.fechaNac;
        }
        if (fallecimientoInput && perfilDetectado.fechaFal) {
            fallecimientoInput.value = perfilDetectado.fechaFal;
        }
        if (biografiaInput && perfilDetectado.biografia) {
            biografiaInput.value = perfilDetectado.biografia;
        }

        // Una vez completado, ocultamos la sugerencia de manera elegante
        document.getElementById('ai-autocomplete-container').classList.add('d-none');
    }

    // 3. GENERADOR DE BIOGRAFÍA TRADICIONAL (Para artistas no reconocidos / ficticios)
    async function autogenerarSoloBiografia() {
        const nombre = document.getElementById('inputNombre').value.trim();
        const apellido = document.getElementById('inputApellido').value.trim();
        const nacionalidad = document.getElementById('inputNacionalidad').value.trim();

        if (!nombre) {
            alert("⚠️ Por favor, ingrese el nombre del artista.");
            return;
        }

        const biografiaInput = document.getElementById('biografia');
        const originalPlaceholder = biografiaInput.placeholder;
        biografiaInput.value = "";
        biografiaInput.placeholder = "Redactando reseña artística profesional con Llama-3...";

        try {
            const res = await fetch('/admin/artistas/generar-biografia', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, apellido, nacionalidad })
            });
            const data = await res.json();

            if (data.success && data.profile) {
                biografiaInput.value = data.profile.biografia;
            } else {
                biografiaInput.value = `Maestro contemporáneo nacido en ${nacionalidad || 'su país de origen'}. Su obra se enfoca en el desarrollo de lenguajes visuales avanzados.`;
            }
        } catch (err) {
            console.error(err);
            alert("No se pudo conectar con el servicio de IA.");
        } finally {
            biografiaInput.placeholder = originalPlaceholder;
        }
    }
</script>