<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     /* Azul Carbono */
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-yellow-soft: rgba(251, 191, 36, 0.12); 
        --at-yellow-text: #fcd34d;
        --at-red-soft: rgba(239, 68, 68, 0.12);    
        --at-red-text: #fca5a5;
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* CARD DE FORMULARIO Y TABLA */
    .admin-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    /* INPUTS ESTILO DARK */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    .input-custom::placeholder {
        color: #64748b !important;
    }

    /* BOTONES ESTILIZADOS */
    .btn-atrium-orange {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }
    
    .btn-atrium-orange:hover { 
        transform: translateY(-3px); 
        filter: brightness(1.1);
        box-shadow: 0 15px 30px var(--at-orange-glow); /* Efecto Glow añadido */
    }

    /* ESTILO DE LA TABLA */
    .table-atrium {
        color: white !important;
        margin-bottom: 0;
    }

    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; 
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 18px;
        border: none;
    }

    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 18px;
        vertical-align: middle;
    }

    /* BOTONES DE ACCIÓN SOFT */
    .btn-edit-soft {
        background-color: var(--at-yellow-soft) !important;
        color: var(--at-yellow-text) !important;
        border: 1px solid rgba(251, 191, 36, 0.2) !important;
        font-weight: 700;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.75rem;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-edit-soft:hover {
        background-color: rgba(251, 191, 36, 0.25) !important;
        transform: translateY(-2px);
    }

    .btn-delete-soft {
        background-color: var(--at-red-soft) !important;
        color: var(--at-red-text) !important;
        border: 1px solid rgba(239, 68, 68, 0.2) !important;
        font-weight: 700;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.75rem;
        border: none;
        transition: 0.3s;
    }
    .btn-delete-soft:hover {
        background-color: rgba(239, 68, 68, 0.25) !important;
        transform: translateY(-2px);
    }

    .btn-back-atrium {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-back-atrium:hover { color: white; border-color: white; background: rgba(255,255,255,0.03); }

    .img-artist-thumb {
        width: 50px; height: 50px; object-fit: cover; border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.1);
    }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1000px;">
        
        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="admin-title m-0">👨‍🎨 Gestión de Artistas</h2>
            <button class="btn btn-atrium-orange shadow-lg" type="button" data-bs-toggle="collapse" data-bs-target="#formArtista">
                + AGREGAR ARTISTA
            </button>
        </div>

        <!-- FORMULARIO DE REGISTRO COLAPSABLE -->
        <div class="collapse mb-5" id="formArtista">
            <div class="admin-card">
                <h4 class="text-white mb-4 fw-bold" style="letter-spacing: -1px;">Registrar Nuevo Artista</h4>
                <form action="/admin/guardar-artista" method="POST" enctype="multipart/form-data" class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Nombre</label>
                        <input type="text" name="nombre" class="form-control input-custom" required placeholder="Nombre del autor">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Apellido</label>
                        <input type="text" name="apellido" class="form-control input-custom" placeholder="Apellido del autor">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label-custom">Nacionalidad</label>
                        <input type="text" name="nacionalidad" class="form-control input-custom" required placeholder="Ej: Venezolano">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label-custom">Nacimiento</label>
                        <input type="date" name="fechaNac" class="form-control input-custom">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label-custom">Fallecimiento</label>
                        <input type="date" name="fechaFal" class="form-control input-custom">
                    </div>
                    <div class="col-12">
                        <label class="form-label-custom">Biografía</label>
                        <textarea name="biografia" class="form-control input-custom" rows="3" placeholder="Reseña histórica del artista..."></textarea>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label-custom">Fotografía del Autor</label>
                        <input type="file" name="foto" class="form-control input-custom" accept="image/*" style="padding: 8px !important;">
                    </div>
                    
                    <!-- BOTÓN DE GUARDAR CON EFECTO GLOW -->
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-atrium-orange px-5">Guardar Artista</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- LISTADO DE ARTISTAS -->
        <div class="admin-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-atrium align-middle text-center">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Perfil</th>
                            <th>Nombre Completo</th>
                            <th>Nacionalidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% artistas.forEach(a => { %>
                            <tr>
                                <td>
                                    <% if(a.fotografia) { %>
                                        <img src="/uploads/<%= a.fotografia %>" class="img-artist-thumb" alt="Foto">
                                    <% } else { %>
                                        <div class="rounded-circle bg-dark border border-secondary d-inline-flex align-items-center justify-content-center" style="width:50px; height:50px">👤</div>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="fw-bold text-white"><%= a.nombre %> <%= a.apellido %></div>
                                    <small class="text-white-50">ID: #<%= a.id %></small>
                                </td>
                                <td>
                                    <span class="badge bg-dark border border-secondary text-white-50 px-3 py-2"><%= a.nacionalidad %></span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a href="/admin/editar-artista/<%= a.id %>" class="btn-edit-soft">Editar</a>
                                        <a href="/admin/eliminar-artista/<%= a.id %>" class="btn-delete-soft" onclick="return confirm('¿Eliminar este artista de forma permanente?')">Borrar</a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (artistas.length === 0) { %>
                            <tr><td colspan="4" class="p-5 text-white-50">No hay artistas registrados en el sistema.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- REGRESO -->
        <div class="text-start mt-5 mb-5">
            <a href="/admin/dashboard" class="btn btn-back-atrium shadow-sm">
                ← Volver al Panel Administrativo
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>