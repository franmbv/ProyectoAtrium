<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     /* Azul Carbono */
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    /* CARD DE EDICIÓN ESTILO CARBONO */
    .edit-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 20px;
        padding: 45px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-label-custom {
        display: block;
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        text-align: left;
    }

    /* INPUTS ESTILO DARK */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 12px !important;
        transition: all 0.3s;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    /* ESTILIZACIÓN DEL BOTÓN EXAMINAR */
    .input-custom[type="file"] {
        padding: 0 !important;
        display: flex;
        align-items: center;
    }

    .input-custom::file-selector-button {
        background-color: #334155;
        color: white;
        border: none;
        border-right: 1px solid var(--at-border);
        padding: 0 20px;
        margin-right: 15px;
        height: 46px;
        border-radius: 9px 0 0 9px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.3s;
    }

    .input-custom::file-selector-button:hover {
        background-color: var(--at-orange);
    }

    /* BOTONES */
    .btn-atrium-save {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 14px 40px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }

    .btn-atrium-save:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 15px 30px var(--at-orange-glow);
    }

    .btn-atrium-cancel {
        background: transparent;
        color: #64748b;
        border: 1px solid #334155;
        border-radius: 100px;
        padding: 12px 30px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }

    .btn-atrium-cancel:hover {
        color: white;
        border-color: white;
        background: rgba(255,255,255,0.03);
    }

    /* PREVISUALIZACIÓN DE FOTO */
    .current-photo-box {
        border: 1px solid var(--at-border);
        background: #0d1117;
        padding: 15px;
        border-radius: 12px;
        display: inline-block;
    }

    .img-edit-preview {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid var(--at-orange-glow);
    }

    textarea.input-custom {
        height: auto;
    }

    select option {
        background-color: #0d1117;
        color: white;
    }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 900px;">
        
        <div class="edit-card">
            <h2 class="admin-title mb-5">✏️ Editar Artista</h2>
            
            <form action="/admin/actualizar-artista/<%= artista.id %>" method="POST" enctype="multipart/form-data">
                
                <!-- Nombre y Apellido -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Nombre</label>
                        <input type="text" name="nombre" class="form-control input-custom" value="<%= artista.nombre %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Apellido</label>
                        <input type="text" name="apellido" class="form-control input-custom" value="<%= artista.apellido %>">
                    </div>
                </div>

                <!-- Fechas -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Fecha de Nacimiento</label>
                        <input type="date" name="fechaNac" class="form-control input-custom" value="<%= artista.fechaNac ? new Date(artista.fechaNac).toISOString().split('T')[0] : '' %>" style="color-scheme: dark;">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Fecha de Fallecimiento</label>
                        <input type="date" name="fechaFal" class="form-control input-custom" value="<%= artista.fechaFal ? new Date(artista.fechaFal).toISOString().split('T')[0] : '' %>" style="color-scheme: dark;">
                    </div>
                </div>

                <!-- Nacionalidad -->
                <div class="mb-4">
                    <label class="form-label-custom">Nacionalidad</label>
                    <input type="text" name="nacionalidad" class="form-control input-custom" value="<%= artista.nacionalidad %>" required>
                </div>

                <!-- Biografía -->
                <div class="mb-4">
                    <label class="form-label-custom">Biografía</label>
                    <textarea name="biografia" class="form-control input-custom" rows="5" placeholder="Escriba aquí la reseña del artista..."><%= artista.descripcion %></textarea>
                </div>

                <!-- Foto -->
                <div class="mb-5">
                    <label class="form-label-custom">Actualizar Fotografía</label>
                    <input type="file" name="foto" class="form-control input-custom" accept="image/*">
                    
                    <% if(artista.fotografia) { %>
                        <div class="mt-4">
                            <div class="current-photo-box">
                                <p class="small text-white-50 mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">Foto Actual</p>
                                <img src="/uploads/<%= artista.fotografia %>" class="img-edit-preview" alt="Foto Artista">
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- ACCIONES -->
                <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-10">
                    <a href="/admin/gestion-artistas" class="btn-atrium-cancel">
                        Cancelar
                    </a>
                    <button type="submit" class="btn-atrium-save shadow-lg">
                        Guardar Cambios