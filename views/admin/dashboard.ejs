<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
    /* VARIABLES DE COLOR PARA ARMONÍA TOTAL */
    :root {
        --dash-bg: #161b22;      /* Azulado oscuro de tus paneles */
        --dash-border: #30363d;   /* Borde sutil */
        --atrium-orange: #f97316; /* Naranja principal */
        --atrium-ink: #0d1117;    /* Negro profundo para contraste */
        
        /* Colores de los cuadros (KPIs) basados en tu imagen */
        --kpi-gray: #bfc9d1;
        --kpi-dark: #25343f;
        --kpi-orange: #ff9b51;
    }

    .admin-dashboard-wrapper {
        padding: 40px 20px;
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
    }

    /* CONTENEDOR PRINCIPAL - INTEGRADO AL DISEÑO OSCURO */
    .dashboard-panel {
        background-color: var(--dash-bg) !important;
        border: 1px solid var(--dash-border);
        border-radius: 20px;
        padding: 45px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .dashboard-title {
        color: #ffffff !important;
        text-align: left !important;
        font-weight: 800;
        margin-bottom: 35px;
        letter-spacing: -1px;
        font-size: 2.2rem;
    }

    /* ESTILO DE LOS 4 CONTADORES (KPIs) - RELLENO SÓLIDO PREMIUM */
    .admin-kpi {
        border: 0;
        border-radius: 16px;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 30px 10px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        min-width: 0; /* Asegura que el contenido no desborde el flex-item */
    }
    
    .admin-kpi:hover { 
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4);
    }

    .admin-kpi h5 {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        text-align: center !important;
        width: 100%;
    }

    .admin-kpi .display-value {
        /* Tipografía elástica: se achica sola si el número es gigante */
        font-size: clamp(1rem, 2.5vw, 2.5rem) !important; 
        font-weight: 900;
        margin: 0;
        text-align: center !important;
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis; /* Si aun así no cabe, pone "..." */
        white-space: nowrap;
        display: block;
    }

    /* COLORES DE LOS CUADROS - CONTRASTE GARANTIZADO */
    .kpi-gray { background-color: var(--kpi-gray) !important; }
    .kpi-gray h5, .kpi-gray .display-value { color: #161b22 !important; }

    .kpi-dark { background-color: var(--kpi-dark) !important; border: 1px solid var(--dash-border) !important; }
    .kpi-dark h5, .kpi-dark .display-value { color: #ffffff !important; }

    .kpi-orange { background-color: var(--kpi-orange) !important; }
    .kpi-orange h5, .kpi-orange .display-value { color: #000000 !important; }

    /* LISTA DE ACCIONES MODERNA (GLASS STYLE) */
    .list-group {
        border-radius: 12px;
        overflow: hidden;
        margin-top: 50px;
        border: 1px solid var(--dash-border);
        background: rgba(0, 0, 0, 0.2);
    }

    /* ENCABEZADO NARANJA ESTÁTICO */
    .list-header {
        background-color: var(--atrium-orange) !important;
        color: #000000 !important;
        font-weight: 800;
        padding: 20px 25px !important;
        border: none !important;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.9rem;
    }

    /* BOTONES OSCUROS CON ANIMACIÓN DE DESLIZAMIENTO */
    .list-group-item-action {
        background-color: transparent !important;
        color: #e2e8f0 !important;
        padding: 22px 25px !important;
        font-weight: 600;
        border: none !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 1.05rem;
    }

    .list-group-item-action:hover {
        background-color: rgba(255, 255, 255, 0.03) !important;
        padding-left: 45px !important;
        color: var(--atrium-orange) !important;
    }

    .list-group-item-action .arrow {
        transition: all 0.4s ease;
        opacity: 0;
        transform: translateX(-10px);
        color: var(--atrium-orange);
        font-weight: 900;
    }

    .list-group-item-action:hover .arrow {
        opacity: 1;
        transform: translateX(0);
    }

    .list-group-item-action:last-child { border-bottom: none !important; }
</style>

<div class="admin-dashboard-wrapper">
    <% 
        /* LÓGICA DE FORMATEO PROFESIONAL (Ingeniería de Software) */
        /* Convertimos 1,000 -> 1K | 1,000,000 -> 1M | 1,000,000,000 -> 1B */
        const shortFormat = new Intl.NumberFormat('en-US', {
            notation: 'compact',
            compactDisplay: 'short',
            maximumFractionDigits: 1
        });
    %>

    <div class="dashboard-panel shadow-2xl">
        <h1 class="dashboard-title">Panel Administrativo</h1>

        <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
            <div class="alert alert-danger bg-danger bg-opacity-10 border-0 text-danger mb-4"><%= errorMsg %></div>
        <% } %>

        <!-- BLOQUES DE CONTADORES CON RELLENO SÓLIDO -->
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card admin-kpi kpi-gray preserve-color">
                    <h5>Obras Activas</h5>
                    <p class="display-value"><%= shortFormat.format(stats.totalObras) %></p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card admin-kpi kpi-dark preserve-color">
                    <h5>Total Recaudado</h5>
                    <p class="display-value">$<%= shortFormat.format(99999999999999999999999999999999999) %></p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card admin-kpi kpi-gray preserve-color">
                    <h5>Ganancia Museo</h5>
                    <p class="display-value">$<%= shortFormat.format(stats.gananciaMuseo) %></p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card admin-kpi kpi-orange preserve-color">
                    <h5>Nuevas Membresías</h5>
                    <p class="display-value"><%= shortFormat.format(stats.membresias) %></p>
                </div>
            </div>
        </div>

        <!-- MENÚ DE OPCIONES ESTÉTICO -->
        <div class="list-group shadow-xl">
            <div class="list-group-item list-header">Menú de Operaciones Gerenciales</div>
            
            <a href="/admin/inventario" class="list-group-item list-group-item-action">
                <span><span role="img">🖼️</span>Ver Inventario General</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/gestion-obras" class="list-group-item list-group-item-action">
                <span><span role="img">🎨</span>Registrar Nueva Obra</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/gestion-artistas" class="list-group-item list-group-item-action">
                <span><span role="img">👨‍🎨</span>Gestión de Artistas</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/reservas" class="list-group-item list-group-item-action">
                <span><span role="img">✅</span>Gestión de Reservas</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/reportes-ventas" class="list-group-item list-group-item-action">
                <span><span role="img">📊</span>Reportes de Ventas</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/obras-vendidas" class="list-group-item list-group-item-action">
                <span><span role="img">🧾</span>Historial de Ventas</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/facturas" class="list-group-item list-group-item-action">
                <span><span role="img">📄</span>Facturas por Comprador</span>
                <span class="arrow">→</span>
            </a>
            <a href="/admin/reportes-membresia" class="list-group-item list-group-item-action border-0">
                <span><span role="img">💳</span>Usuarios con Membresía</span>
                <span class="arrow">→</span>
            </a>
            <% if (locals.usuario && locals.usuario.rol === 3) { %>
                <div class="list-group-item list-header mt-4" style="background-color: #0f172a !important; color: var(--atrium-orange) !important;">
                    Funciones de Superadmin
                </div>
                <a href="/admin/usuarios/crear" class="list-group-item list-group-item-action" style="border-bottom: none !important;">
                    <span>👑 Añadir Nuevo Administrador</span>
                    <span class="arrow">→</span>
                </a>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>