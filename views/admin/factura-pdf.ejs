<!-- Archivo: views/admin/factura-pdf.ejs -->
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Factura <%= factura.codigoDeFactura %></title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #333; margin: 0; padding: 20px; }
        .header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 20px; }
        .header h1 { margin: 0; font-size: 24px; text-transform: uppercase; }
        .row { display: table; width: 100%; margin-bottom: 10px; }
        .col { display: table-cell; width: 50%; }
        .table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        .table th, .table td { border: 1px solid #ccc; padding: 10px; text-align: left; }
        .table th { background-color: #f5f5f5; }
        .totals { margin-top: 20px; width: 50%; float: right; border-collapse: collapse; }
        .totals td { padding: 8px; border-bottom: 1px solid #eee; }
        .totals .bold { font-weight: bold; }
        .footer { clear: both; margin-top: 50px; text-align: center; font-size: 10px; color: #777; }
    </style>
</head>
<body>
    <div class="header">
        <h1>MUSEO ATRIUM</h1>
        <p>Comprobante Oficial de Venta</p>
    </div>

    <div class="row">
        <div class="col">
            <strong>FACTURA N°:</strong> <%= factura.codigoDeFactura %><br>
            <strong>FECHA:</strong> <%= new Date(factura.fechaDeVenta || factura.fechadeventa).toLocaleDateString() %><br>
            <strong>COURIER:</strong> <%= factura.empresaEnvio %><br>
            <strong>ADMIN ID:</strong> <%= factura.administrador_id %>
        </div>
        <div class="col">
            <strong>CLIENTE:</strong> <%= factura.nombre_comprador %> <%= factura.apellido_comprador %><br>
            <strong>CÉDULA:</strong> <%= factura.cedula %><br>
            <strong>EMAIL:</strong> <%= factura.gmail %><br>
            <strong>DIRECCIÓN:</strong> <%= factura.calle %>, <%= factura.ciudad %>, <%= factura.pais %>
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>DESCRIPCIÓN DE LA OBRA</th>
                <th>AUTOR</th>
                <th>PRECIO BASE</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong><%= factura.nombre_obra %></strong></td>
                <td><%= factura.nombre_artista %> <%= factura.apellido_artista %></td>
                <td>$<%= parseFloat(factura.precioObra || factura.precioobra || 0).toFixed(2) %></td>
            </tr>
        </tbody>
    </table>

    <table class="totals">
        <tr>
            <td>Subtotal:</td>
            <td style="text-align: right;">$<%= parseFloat(factura.precioFinalVenta - factura.iva - factura.gananciaMuseoDolares).toFixed(2) %></td>
        </tr>
        <tr>
            <td>IVA (16%):</td>
            <td style="text-align: right;">$<%= parseFloat(factura.iva).toFixed(2) %></td>
        </tr>
        <tr>
            <td>Comisión Museo:</td>
            <td style="text-align: right;">$<%= parseFloat(factura.gananciaMuseoDolares || factura.gananciamuseodolares).toFixed(2) %></td>
        </tr>
        <tr>
            <td class="bold">TOTAL A PAGAR:</td>
            <td class="bold" style="text-align: right;">$<%= parseFloat(factura.precioFinalVenta || factura.preciofinalventa).toFixed(2) %></td>
        </tr>
    </table>

    <div class="footer">
        Documento generado electrónicamente. Autenticidad garantizada por Museo Atrium.
    </div>
</body>
</html>