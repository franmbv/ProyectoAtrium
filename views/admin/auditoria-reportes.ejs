<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-border: rgba(255, 255, 255, 0.08);
    }

    .admin-page-wrapper {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: 100vh;
        padding: 60px 0;
        font-family: 'Inter', sans-serif;
    }

    .admin-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -1.5px;
    }

    .kpi-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .kpi-card {
        background-color: var(--at-card-bg);
        border: 1px solid var(--at-border);
        border-radius: 12px;
        padding: 24px;
        text-align: left;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .kpi-card h5 {
        color: #64748b;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 800;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .kpi-card p {
        color: white;
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0;
    }

    .smart-filter-bar {
        background-color: var(--at-card-bg);
        border: 1px solid var(--at-border);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .inventory-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        margin-bottom: 45px;
    }

    .section-subtitle {
        font-size: 1rem;
        font-weight: 800;
        color: #64748b;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }

    .table-atrium { color: white !important; margin-bottom: 0; }
    .table-atrium thead th {
        background-color: var(--at-orange) !important;
        color: #000000 !important; 
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        padding: 14px;
        border: none;
        text-align: center;
    }

    .table-atrium tbody td {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
        padding: 14px;
        color: #e2e8f0;
        vertical-align: middle;
        text-align: center;
    }

    .input-dark {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        border-radius: 10px;
    }
</style>

<div class="admin-page-wrapper">
    <div class="container" style="max-width: 1100px;">
        
        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="admin-title"><span role="img">📊</span> Auditoría de Reportes</h2>
                <p class="text-white-50 m-0">Conciliación de registros financieros e históricos de membresía NoSQL (Cassandra)</p>
            </div>
            <a href="/admin/dashboard" class="btn-new-atrium" style="background-color: rgba(255,255,255,0.05) !important; border: 1px solid var(--at-border) !important; color: #94a3b8 !important;">
                Panel Principal
            </a>
        </div>

        <!-- FILTROS INTELIGENTES -->
        <div class="smart-filter-bar">
            <form action="/admin/auditoria/reportes" method="GET" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="section-subtitle mb-2 d-block">Año Fiscal</label>
                    <select name="anio" class="form-select input-dark">
                        <option value="2026" <%= anio == 2026 ? 'selected' : '' %>>2026</option>
                        <option value="2025" <%= anio == 2025 ? 'selected' : '' %>>2025</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="section-subtitle mb-2 d-block">Mes de Análisis</label>
                    <select name="mes" class="form-select input-dark">
                        <% const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"]; %>
                        <% meses.forEach((m, idx) => { %>
                            <option value="<%= idx + 1 %>" <%= mes == (idx + 1) ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-new-atrium w-100 p-2" style="border-radius: 10px;">
                        Analizar Periodo
                    </button>
                </div>
            </form>
        </div>

        <!-- SECCIÓN KPI METRICAS -->
        <% 
            let totalFacturado = 0; 
            let totalGananciaMuseo = 0;
            facturas.forEach(f => {
                totalFacturado += parseFloat(f.monto_neto || 0);
                totalGananciaMuseo += parseFloat(f.ganancia_museo || 0);
            });
            let totalMembresias = membresias.length * 10.0;
        %>
        <div class="kpi-container">
            <div class="kpi-card">
                <h5>Monto Neto Facturado</h5>
                <p>$<%= totalFacturado.toLocaleString('en-US', { minimumFractionDigits: 2 }) %></p>
            </div>
            <div class="kpi-card">
                <h5>Comisiones Museo</h5>
                <p>$<%= totalGananciaMuseo.toLocaleString('en-US', { minimumFractionDigits: 2 }) %></p>
            </div>
            <div class="kpi-card">
                <h5>Ingresos Membresías</h5>
                <p>$<%= totalMembresias.toLocaleString('en-US', { minimumFractionDigits: 2 }) %></p>
            </div>
        </div>

        <!-- TABLA FACTURACIÓN -->
        <h6 class="section-subtitle">CONCILIACIÓN DE FACTURAS</h6>
        <div class="inventory-card">
            <div class="table-responsive">
                <table class="table table-atrium align-middle">
                    <thead>
                        <tr>
                            <th>Factura ID</th>
                            <th>Fecha Emisión</th>
                            <th>Monto Neto</th>
                            <th>IVA Calculado</th>
                            <th>Ganancia Museo</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (facturas && facturas.length > 0) { %>
                            <% facturas.forEach(f => { %>
                                <tr>
                                    <td class="font-monospace text-warning fw-bold">FAC-<%= String(f.id_factura).slice(-6) %></td>
                                    <td class="text-white-50"><%= new Date(f.fecha_emision).toLocaleDateString() %></td>
                                    <td class="fw-bold text-white">$<%= parseFloat(f.monto_neto).toFixed(2) %></td>
                                    <td class="text-white-50">$<%= parseFloat(f.iva_calculado).toFixed(2) %></td>
                                    <td class="text-success">$<%= parseFloat(f.ganancia_museo).toFixed(2) %></td>
                                    <td><span class="badge bg-success bg-opacity-10 text-success p-2 border border-success border-opacity-25" style="border-radius: 6px;"><%= f.estado %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="p-4 text-white-50">No hay registros de facturación fiscal en este periodo.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TABLA MEMBRESÍAS -->
        <h6 class="section-subtitle">REGISTROS DE COBRO DE MEMBRESÍA</h6>
        <div class="inventory-card">
            <div class="table-responsive">
                <table class="table table-atrium align-middle">
                    <thead>
                        <tr>
                            <th>ID Membresía</th>
                            <th>Fecha Registro</th>
                            <th>Código de Seguridad</th>
                            <th>Monto Cobrado</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (membresias && membresias.length > 0) { %>
                            <% membresias.forEach(m => { %>
                                <tr>
                                    <td class="font-monospace text-white-50">MEM-#<%= m.id_membresia %></td>
                                    <td class="text-white-50"><%= new Date(m.fecha_registro).toLocaleDateString() %></td>
                                    <td class="font-monospace text-warning fw-bold"><%= m.codigo_membresia %></td>
                                    <td class="fw-bold text-white">$<%= parseFloat(m.monto_cobrado).toFixed(2) %></td>
                                    <td><span class="badge bg-success bg-opacity-10 text-success p-2 border border-success border-opacity-25" style="border-radius: 6px;"><%= m.estado %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="p-4 text-white-50">No hay registros de cobros de membresía en este periodo.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<%- include('../partials/footer') %>