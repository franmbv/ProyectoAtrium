<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-4" style="max-width: 1000px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold">Reservas de Obras</h2>
        <a href="/admin/inventario" class="btn btn-outline-light">Ver Inventario</a>
    </div>

    <div class="table-responsive shadow-sm mb-4 bg-white rounded overflow-hidden">
        <table class="table table-striped table-hover align-middle w-100 mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 70px;">Imagen</th>
                    <th>Obra</th>
                    <th>Artista</th>
                    <th>Genero</th>
                    <th>Estatus</th>
                    <th>Precio</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (obras.length > 0) { %>
                    <% obras.forEach(o => { %>
                        <tr>
                            <td style="width: 70px;">
                                <img src="<%= o.foto ? ('/uploads/' + o.foto) : '/img/default_obra.jpg' %>" alt="<%= o.nombre %>" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;">
                            </td>
                            <td><%= o.nombre %></td>
                            <td><%= o.nombre_artista %> <%= o.apellido_artista %></td>
                            <td><%= o.nombre_genero %></td>
                            <td><span class="badge bg-warning text-dark"><%= o.estatus %></span></td>
                            <td>$<%= parseFloat(o.precioObra).toLocaleString('en-US') %></td>
                            <td class="d-flex gap-2">
                                <a href="/admin/facturar/<%= o.id %>" class="btn btn-sm btn-success">Aceptar</a>
                                <form action="/admin/reservas/<%= o.id %>/rechazar" method="POST" onsubmit="return confirm('¿Rechazar la reserva y devolver la obra a Disponible?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Rechazar</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="7" class="text-center">No hay obras reservadas.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="text-center mt-5 mb-5">
        <a href="/admin/dashboard" class="btn btn-secondary shadow-sm">← Volver al Panel Administrativo</a>
    </div>
</div>

<%- include('../partials/footer') %>
