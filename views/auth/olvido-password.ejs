<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;
        --at-navy-darkest: #020617;
        --at-card-bg: #161b22;
        --at-orange: #f97316;
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    .auth-page-container {
        background: linear-gradient(180deg, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    .recover-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 16px;
        padding: 45px 35px;
        width: 100%;
        max-width: 560px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
        text-align: center;
    }

    .recover-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 900;
        color: white;
        margin: 0 0 10px 0;
    }

    .recover-subtitle {
        color: #94a3b8;
        font-size: 0.95rem;
        margin-bottom: 30px;
        line-height: 1.5;
    }

    .step-badge {
        display: inline-block;
        color: var(--at-orange);
        border: 1px solid rgba(249, 115, 22, 0.3);
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.75rem;
        margin-bottom: 18px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .form-group-custom {
        width: 100%;
        margin-bottom: 18px;
        text-align: left;
    }

    .form-label-custom {
        display: block;
        color: #94a3b8;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 8px;
    }

    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        padding: 12px 14px !important;
        border-radius: 10px !important;
        width: 100%;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 12px var(--at-orange-glow) !important;
        outline: none;
    }

    .btn-atrium-main {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 14px 0;
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        margin-top: 10px;
        cursor: pointer;
    }

    .btn-back {
        display: inline-block;
        margin-top: 18px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.85rem;
    }

    .btn-back:hover {
        color: var(--at-orange);
    }

    .alert-recover {
        width: 100%;
        background: rgba(239, 68, 68, 0.1);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 10px;
        font-size: 0.85rem;
        padding: 12px;
        margin-bottom: 20px;
        text-align: center;
    }

    .question-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 14px;
        text-align: left;
    }

    .question-text {
        color: #e2e8f0;
        margin-bottom: 10px;
        font-size: 0.95rem;
    }
</style>

<div class="auth-page-container">
    <div class="recover-card">
        <div style="font-size: 44px; margin-bottom: 8px;">🔒</div>
        <h1 class="recover-title">Recuperar contraseña</h1>

        <% if (!mostrarCambio) { %>
            <p class="recover-subtitle">Ingrese su usuario para verificar sus preguntas de seguridad.</p>
        <% } else { %>
            <p class="recover-subtitle">Responda correctamente y establezca una nueva contraseña para ingresar de nuevo al museo.</p>
        <% } %>

        <% if (error) { %>
            <div class="alert-recover" role="alert"><%= error %></div>
        <% } %>

        <% if (!mostrarCambio) { %>
            <span class="step-badge">Paso 1</span>
            <form action="/auth/olvido-password/verificar-usuario" method="POST">
                <div class="form-group-custom">
                    <label class="form-label-custom">Usuario / Login</label>
                    <input type="text" name="login" class="input-custom" placeholder="Ingrese su usuario" required>
                </div>
                <button type="submit" class="btn-atrium-main">Verificar preguntas</button>
            </form>
        <% } else { %>
            <span class="step-badge">Paso 2</span>
            <form action="/auth/olvido-password/cambiar" method="POST">
                <input type="hidden" name="login" value="<%= login %>">

                <% preguntas.forEach((item, index) => { %>
                    <div class="question-box">
                        <label class="form-label-custom">Pregunta <%= index + 1 %></label>
                        <p class="question-text"><%= item.pregunta %></p>
                        <input type="text" name="respuestas[]" class="input-custom" placeholder="Respuesta" required autocomplete="off">
                    </div>
                <% }) %>

                <div class="form-group-custom">
                    <label class="form-label-custom">Nueva contraseña</label>
                    <input type="password" name="nuevaPassword" class="input-custom" minlength="6" placeholder="Mínimo 6 caracteres" required>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Confirmar contraseña</label>
                    <input type="password" name="confirmarPassword" class="input-custom" minlength="6" placeholder="Repita su nueva contraseña" required>
                </div>

                <button type="submit" class="btn-atrium-main">Guardar nueva contraseña</button>
            </form>
        <% } %>

        <a href="/auth/login" class="btn-back">Volver al inicio de sesión</a>
    </div>
</div>

<%- include('../partials/footer') %>
