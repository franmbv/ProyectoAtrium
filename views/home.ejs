<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Tipografías de alta gama -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background: var(--at-navy-darkest) !important;
        color: white !important;
    }

    /* CONTENEDOR PRINCIPAL: Degradado inmersivo */
    .landing-wrapper {
        position: relative;
        overflow: hidden;
        background: radial-gradient(circle at center, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: calc(100vh - 70px); /* Ajuste para que no flote el footer */
        display: flex;
        align-items: center;
        width: 100%;
    }

    /* MOSAICO PINTEREST REFINADO */
    .pinterest-grid {
        position: absolute;
        right: -5%;
        top: 0;
        width: 55%;
        height: 120%;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
        transform: rotate(-10deg) translateY(-5%);
        opacity: 0.3;
        pointer-events: none;
        z-index: 1;
    }

    .art-brick {
        width: 100%;
        height: 450px;
        border-radius: 24px;
        background-size: cover;
        background-position: center;
        border: 1px solid var(--at-border);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    /* CARD DE PRESENTACIÓN: Glassmorphism en Azul Carbono */
    .hero-card {
        position: relative;
        z-index: 10;
        max-width: 750px;
        background: rgba(22, 27, 34, 0.8) !important; /* Azul Carbono traslúcido */
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 60px;
        border-radius: 32px;
        border: 1px solid var(--at-border);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.8);
        margin-left: 20px;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: 4.2rem;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 25px;
        letter-spacing: -3px;
        color: white !important;
    }

    .hero-subtitle {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        color: #94a3b8 !important;
        line-height: 1.6;
        margin-bottom: 45px;
        font-weight: 300;
        max-width: 550px;
    }

    /* BOTONES */
    .btn-atrium-main {
        background-color: var(--at-orange) !important;
        color: white !important;
        padding: 18px 45px;
        border-radius: 100px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 25px rgba(249, 115, 22, 0.3);
    }

    .btn-atrium-main:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 15px 35px rgba(249, 115, 22, 0.5);
    }

    .link-register-hero {
        color: white !important;
        text-decoration: none;
        font-weight: 600;
        margin-left: 35px;
        padding-bottom: 5px;
        border-bottom: 2px solid var(--at-orange);
        transition: 0.3s;
    }

    .link-register-hero:hover {
        color: var(--at-orange) !important;
        border-color: white;
    }

    @media (max-width: 992px) {
        .pinterest-grid { display: none; }
        .hero-card { margin: 20px; text-align: center; padding: 40px 30px; }
        .hero-title { font-size: 3rem; }
        .hero-subtitle { margin-bottom: 30px; }
        .link-register-hero { display: block; margin: 30px 0 0 0; border: none; }
    }
</style>

<div class="landing-wrapper">
    <!-- Mosaico Pinterest Decorativo -->
    <div class="pinterest-grid">
        <div class="art-brick" style="background-image: url('https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?q=80&w=400'); margin-top: 60px;"></div>
        <div class="art-brick" style="background-image: url('https://images.unsplash.com/photo-1547826039-bfc35e0f1ea8?q=80&w=400');"></div>
        <div class="art-brick" style="background-image: url('https://images.unsplash.com/photo-1578301978693-85fa9c0320b9?q=80&w=400'); margin-top: -40px;"></div>
        <div class="art-brick" style="background-image: url('https://images.unsplash.com/photo-1549490349-8643362247b5?q=80&w=400');"></div>
    </div>

    <div class="container">
        <div class="hero-card shadow-2xl">
            <h1 class="hero-title">
                Inmortaliza el <br><span style="color: var(--at-orange)">Arte</span> en tu Espacio.
            </h1>
            <p class="hero-subtitle">
                Atrium es el portal oficial del Museo de Arte Contemporáneo. 
                Adquiere piezas únicas, apoya al talento nacional y construye 
                tu legado artístico con certificación institucional.
            </p>
            
            <div class="d-flex align-items-center flex-wrap justify-content-center justify-content-lg-start">
                <a href="/galeria" class="btn-atrium-main">
                    Explorar Colección <span style="font-size: 1.2rem;">→</span>
                </a>
                
                <% if (!locals.usuario) { %>
                    <a href="/auth/registro" class="link-register-hero">
                        Registrarme como comprador
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>