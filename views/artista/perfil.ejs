<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= artista.nombre %> <%= artista.apellido %> | Biografía</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .bio-header { background: #212529; color: white; padding: 60px 0; }
        .artist-img { width: 200px; height: 200px; object-fit: cover; border: 5px solid white; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .obra-card img { height: 180px; object-fit: cover; }
    </style>
</head>
<body class="bg-light">

    <%- include('../partials/navbar') %>

    <!-- Cabecera Biográfica -->
    <header class="bio-header text-center">
        <div class="container">
            <% if(artista.fotografia) { %>
                <img src="/uploads/<%= artista.fotografia %>" alt="<%= artista.nombre %>" class="rounded-circle artist-img mb-3">
            <% } else { %>
                <div class="artist-img rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center fs-1 mb-3">
                    👤
                </div>
            <% } %>
            <h1 class="display-4 fw-bold"><%= artista.nombre %> <%= artista.apellido %></h1>
            <p class="lead text-white-50"><%= artista.nacionalidad %></p>
            
            <div class="mt-2">
                <% if(artista.fechaNac) { %>
                    <span class="badge bg-light text-dark">★ <%= new Date(artista.fechaNac).toLocaleDateString() %></span>
                <% } %>
                <% if(artista.fechaFal) { %>
                    <span class="badge bg-secondary text-white">✝ <%= new Date(artista.fechaFal).toLocaleDateString() %></span>
                <% } %>
            </div>
        </div>
    </header>

    <div class="container py-5">
        <!-- Texto de la Biografía -->
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8">
                <div class="card shadow-sm p-4">
                    <h3 class="mb-3 border-bottom pb-2">Sobre el Artista</h3>
                    <p class="fs-5 text-secondary" style="line-height: 1.8;">
                        <%= artista.descripcion || "No hay información biográfica disponible para este artista." %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Obras del Artista -->
        <h3 class="mb-4 text-center">Obras en Exhibición</h3>
        
        <% if(obras.length === 0) { %>
            <div class="alert alert-info text-center">Este artista aún no tiene obras registradas en el sistema.</div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-4 g-4">
                <% obras.forEach(o => { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 obra-card">
                            <img src="<%= o.foto ? '/uploads/'+o.foto : '/img/default_obra.jpg' %>" class="card-img-top" alt="<%= o.nombre %>">
                            <div class="card-body">
                                <h6 class="card-title fw-bold"><%= o.nombre %></h6>
                                <span class="badge bg-light text-dark border"><%= o.nombre_genero %></span>
                                <div class="mt-2 text-end">
                                    <a href="/galeria/detalle/<%= o.id %>" class="btn btn-sm btn-outline-primary stretched-link">Ver Obra</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
        
        <div class="text-center mt-5">
            <a href="/galeria" class="btn btn-secondary">← Volver a la Galería</a>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>