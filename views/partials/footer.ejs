<script>
    const themeToggle = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const rootElement = document.documentElement; // Esto es la etiqueta <html>

    // 1. Al cargar la página, aplicar el tema guardado
    const currentTheme = localStorage.getItem('atrium-theme') || 'dark';
    rootElement.setAttribute('data-theme', currentTheme);
    updateThemeUI(currentTheme);

    // 2. Evento de click para cambiar
    if(themeToggle) {
        themeToggle.addEventListener('click', () => {
            const theme = rootElement.getAttribute('data-theme');
            const newTheme = (theme === 'dark') ? 'light' : 'dark';
            
            rootElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('atrium-theme', newTheme);
            updateThemeUI(newTheme);
        });
    }

    function updateThemeUI(theme) {
        if(themeIcon) {
            themeIcon.innerText = (theme === 'dark') ? '🌙' : '☀️';
        }
    }
</script>



    <!-- Scripts de Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
