</main> <!-- Cierre del contenedor principal -->

    <!-- Elemento oculto para transferir datos de notificación -->
    <div id="flash-info" 
         data-type="<%= locals.flash ? locals.flash.type : '' %>" 
         data-message="<%= locals.flash ? locals.flash.message : '' %>">
    </div>

    <footer class="text-white pt-5 pb-4">
        <div class="container">
            <div class="row g-4">
                <!-- Columna 1: Logo y Eslogan -->
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3" style="color: var(--at-orange); letter-spacing: 1px;"><span role="img">🏛️</span>ATRIUM</h5>
                    <p class="small text-white-50" style="line-height: 1.6;">
                        Portal oficial del Museo de Arte Contemporáneo. <br>
                        Excelencia en gestión de arte y coleccionismo institucional.
                    </p>
                </div>

                <!-- Columna 2: Links Rápidos -->
                <div class="col-md-4">
                    <h6 class="text-uppercase small fw-bold mb-3 opacity-50" style="letter-spacing: 1px;">Navegación</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/galeria" class="text-white-50 text-decoration-none small hover-orange">Colección General</a></li>
                        <% if (locals.usuario) { %>
                            <li><a href="/auth/logout" class="text-white-50 text-decoration-none small hover-orange">Cerrar Sesión</a></li>
                        <% } %>
                    </ul>
                </div>

                <!-- Columna 3: Localización -->
                <div class="col-md-4">
                    <h6 class="text-uppercase small fw-bold mb-3 opacity-50" style="letter-spacing: 1px;">Contacto</h6>
                    <p class="small text-white-50 mb-1"><span role="img">📍</span>Ciudad Guayana, Venezuela</p>
                    <p class="small text-white-50"><span role="img">📧 </span>contacto@atrium.com</p>
                </div>
            </div>

            <!-- Línea de cierre muy sutil -->
            <hr class="mt-4 mb-4" style="border-color: rgba(255,255,255,0.05);">

            <div class="row">
                <div class="col-12 text-center">
                    <p class="small text-white-50 mb-0">
                        &copy; 2026 Proyecto Atrium. <span class="mx-2">|</span> UNEG - Ingeniería en Informática
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <style>
        .hover-orange:hover {
            color: var(--at-orange) !important;
            transition: 0.3s;
        }
    </style>


<script>
    // 1. LÓGICA DEL MODO CLARO/OSCURO
    const themeToggle = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const rootElement = document.documentElement;

    const currentTheme = localStorage.getItem('atrium-theme') || 'dark';
    rootElement.setAttribute('data-theme', currentTheme);
    updateThemeUI(currentTheme);

    if(themeToggle) {
        themeToggle.addEventListener('click', () => {
            const theme = rootElement.getAttribute('data-theme');
            const newTheme = (theme === 'dark') ? 'light' : 'dark';
            rootElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('atrium-theme', newTheme);
            updateThemeUI(newTheme);
        });
    }

    function updateThemeUI(theme) {
        if(themeIcon) {
            themeIcon.innerText = (theme === 'dark') ? '🌙' : '☀️';
        }
    }
// 2. LÓGICA DE NOTIFICACIONES (FLASH) - VERSIÓN DEFINITIVA
   // 2. LÓGICA DE NOTIFICACIONES (FLASH) - INTELIGENTE
    (function() {
        const flashInfo = document.getElementById('flash-info');
        const type = flashInfo.getAttribute('data-type');
        const message = flashInfo.getAttribute('data-message');

        if (type && message) {
            // Iconos por defecto si el mensaje no trae uno
            const defaultIcons = {
                success: '✅',
                error: '❌',
                warning: '⚠️',
                info: 'ℹ️'
            };

            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 1100,
                timerProgressBar: true,
                background: '#161b22', 
                color: '#ffffff',
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                    toast.style.border = '1px solid #f97316';
                }
            });

            // Lógica de detección de emoji
            const emojiRegex = /(\p{Emoji_Presentation}|\p{Emoji}\uFE0F)/u;
            const match = message.match(emojiRegex);
            
            let emoji, cleanText;

            if (match) {
                // Si el mensaje ya trae un emoji (como la manito 👋), lo usamos
                emoji = match[0];
                cleanText = message.replace(emoji, "").trim();
            } else {
                // Si no trae, usamos el del mapa por defecto
                emoji = defaultIcons[type] || '🔔';
                cleanText = message;
            }

            Toast.fire({
                icon: undefined, 
                html: `
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span class="swal-emoji-rescale" style="font-size: 1.4rem;">${emoji}</span>
                        <span class="toast-text-fix" style="font-weight: 700; font-size: 0.95rem;">${cleanText}</span>
                    </div>
                `
            });
        }
    })();
</script>

    <!-- Scripts de Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>