<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>CONFIRMAR RESERVA</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
    <div class="card" role="main" aria-labelledby="titulo">
        <header class="h">
            <h1 id="titulo" >CONFIRMAR RESERVA</h1>
        </header>
        <p class="lead">Ingrese su código de seguridad y el nombre de la obra para validar y reservar (si aplica).</p>

        <form class="grid" method="POST" action="/confirmar-reserva" novalidate>
            <div class="field">
                <label for="codigoSeguridad">Código de seguridad</label>
                <input id="codigoSeguridad" name="codigoSeguridad" type="text" inputmode="numeric" pattern="\d*" required maxlength="20" placeholder="Ej: 123456" autofocus />
                <div class="help">Solo números. Máx. 20 dígitos.</div>
            </div>

            <div class="field">
                <label for="obraNombre">Nombre de la obra</label>
                <input id="obraNombre" name="obraNombre" type="text" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñüÜ ]+" title="Solo letras y espacios" required maxlength="150" placeholder="Ej: Amanecer en la costa" />
                <div class="help">Solo letras y espacios.</div>
            </div>

            <div class="actions" aria-hidden="false">
                <a href="/"><button type="button" class="ghost">Volver</button></a>
                <button type="submit" class="primary">Validar y reservar</button>
            </div>
        </form>

        <% if (typeof message !== 'undefined' && message) { %>
            <div class="mensaje <%= success ? 'success' : 'error' %>">
                <%= message %>
            </div>
        <% } %>
    </div>

    <script>
        // Validación mínima en cliente: solo permitir dígitos en código, solo letras y espacios en obra
        (function(){
            const codigo = document.getElementById('codigoSeguridad');
            const obra = document.getElementById('obraNombre');

            if (codigo) {
                codigo.addEventListener('input', function(e){
                    const v = this.value.replace(/[^\d]/g,'');
                    if (this.value !== v) this.value = v;
                });
            }
            if (obra) {
                obra.addEventListener('input', function(e){
                    const v = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñüÜ ]/g,'');
                    if (this.value !== v) this.value = v;
                });
            }
        })();
    </script>
</body>
</html>
