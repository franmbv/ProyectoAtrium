<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>CONFIRMAR RESERVA</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
    <% // helper para escapar valores y evitar problemas en los atributos value %>
    <% const esc = s => String((s === null || typeof s === 'undefined') ? '' : s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); %>

    <div class="card" role="main" aria-labelledby="titulo">
        <header class="h">
            <h1 id="titulo" >CONFIRMAR RESERVA</h1>
        </header>
        <p class="lead">Ingrese su código de seguridad.</p>

        <form class="grid" method="POST" action="/obra/comprar" novalidate>
            <div class="field">
                <label for="codigoSeguridad">Código de seguridad</label>
                <input id="codigoSeguridad" name="codigoSeguridad" type="text" inputmode="numeric" pattern="\d*" required maxlength="20" placeholder="Ej: 123456" autofocus
                    value="<%= esc((typeof form !== 'undefined' && form.codigoSeguridad) ? form.codigoSeguridad : '') %>" />
                <div class="help">Solo números. Máx. 20 dígitos.</div>
            </div>

            <!-- Mostrar nombre de la obra (no editable) y enviar oculto -->
            <div class="field">
                <% if (form && form.obraNombre) { %>
                    <label class="header">Obra</label>
                    <div class="h1 obra-box">
                        <strong id="obraDisplay"><%= esc(form.obraNombre) %></strong>
                    </div>
                <% } else { %>
                    <label>Obra</label>
                    <div class="obra-box"><em id="obraDisplay">No especificada. Inicie compra desde la página de la obra.</em></div>
                <% } %>
                <input type="hidden" id="obraNombreHidden" name="obraNombre" value="<%= esc((typeof form !== 'undefined' && form.obraNombre) ? form.obraNombre : '') %>" />
            </div>

            <div class="actions">
                <button type="submit" id="comprarAhora" class="primary">Comprar</button>
            </div>
             <div id="obraCheckMessage" style="grid-column:1/-1;margin-top:8px;"></div>
         </form>
     </div>
 
     <script>
         // Validación mínima en cliente: solo permitir dígitos en código
         (function(){
             const codigo = document.getElementById('codigoSeguridad');
             const obraMsg = document.getElementById('obraCheckMessage');
             const obraHidden = document.getElementById('obraNombreHidden');
             const form = document.querySelector('form');

             if (codigo) {
                 codigo.addEventListener('input', function(e){
                     const v = this.value.replace(/[^\d]/g,'');
                     if (this.value !== v) this.value = v;
                 });
             }

             // Helper para obtener nombre de obra (viene oculto)
             const getObraNombre = () => (obraHidden && obraHidden.value) ? obraHidden.value.trim() : '';

             // Si la página recibe obra por query (viene en hidden), auto-verificamos su disponibilidad
             (async function autoCheck() {
                 const nombre = getObraNombre();
                 if (!nombre) return;
                 obraMsg.textContent = 'Verificando disponibilidad de la obra...';
                 obraMsg.className = '';
                 try {
                     const res = await fetch('/obra/check', {
                         method: 'POST',
                         headers: { 'Content-Type': 'application/json' },
                         body: JSON.stringify({ obraNombre: nombre })
                     });
                     const data = await res.json();
                     if (res.ok && data.found && (data.estatus || '').toLowerCase() === 'disponible') {
                         obraMsg.textContent = `La obra "${nombre}" está disponible. Ingrese su código para comprar.`;
                         obraMsg.className = 'mensaje success';
                     } else {
                         obraMsg.textContent = data.message || `Obra "${nombre}" no disponible para compra.`;
                         obraMsg.className = 'mensaje error';
                     }
                 } catch (err) {
                     obraMsg.textContent = 'Error al verificar la obra. Intente de nuevo.';
                     obraMsg.className = 'mensaje error';
                 }
             })();

             // Validar antes de enviar el formulario
             if (form) {
                 form.addEventListener('submit', async function(e){
                     e.preventDefault();
                     obraMsg.textContent = ''; obraMsg.className = '';
                     const nombre = getObraNombre();
                     const codigoVal = (codigo.value || '').trim();
                     if (!nombre) {
                         obraMsg.textContent = 'No se especificó la obra. Inicie la compra desde la página de la obra.';
                         obraMsg.className = 'mensaje error';
                         return;
                     }
                     if (!/^\d+$/.test(codigoVal)) {
                         obraMsg.textContent = 'Código inválido. Solo números.';
                         obraMsg.className = 'mensaje error';
                         return;
                     }
                     // Verificar disponibilidad antes de enviar
                     try {
                         const res = await fetch('/obra/check', {
                             method: 'POST',
                             headers: { 'Content-Type': 'application/json' },
                             body: JSON.stringify({ obraNombre: nombre })
                         });
                         const data = await res.json();
                         if (!(res.ok && data.found && (data.estatus || '').toLowerCase() === 'disponible')) {
                             obraMsg.textContent = data.message || 'Obra no disponible para compra';
                             obraMsg.className = 'mensaje error';
                             return;
                         }
                     } catch (err) {
                         obraMsg.textContent = 'Error al verificar la obra. Intente de nuevo.';
                         obraMsg.className = 'mensaje error';
                         return;
                     }
                     // Si todo bien, enviar el formulario
                     form.submit();
                 });
             }
         })();
     </script>
 </body>
 </html>
