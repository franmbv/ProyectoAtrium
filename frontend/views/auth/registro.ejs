<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- Tipografías elegantes -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --at-navy-deep: #0f172a;   
        --at-navy-darkest: #020617; 
        --at-card-bg: #161b22;     
        --at-orange: #f97316;      
        --at-orange-glow: rgba(249, 115, 22, 0.4);
        --at-border: rgba(255, 255, 255, 0.1);
    }

    /* Contenedor unificado y centrado absoluto */
    .auth-page-container {
        background: radial-gradient(circle at center, var(--at-navy-deep) 0%, var(--at-navy-darkest) 100%) !important;
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    /* Card Azul Carbono */
    .register-card {
        background-color: var(--at-card-bg) !important;
        border: 1px solid var(--at-border) !important;
        border-radius: 24px; 
        padding: 50px 45px;
        width: 100%;
        max-width: 650px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.6);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .register-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 900;
        color: white;
        margin: 0 0 10px 0;
        letter-spacing: -1px;
        text-align: center;
    }

    .brand-highlight {
        color: var(--at-orange) !important;
        text-shadow: 0 0 15px rgba(249, 115, 22, 0.3);
    }

    /* Indicador de Pasos Moderno */
    .step-indicator-container {
        width: 100%;
        margin-bottom: 40px;
        text-align: center;
    }

    .register-subtitle {
        color: var(--at-orange);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 15px;
    }

    .progress-track {
        height: 4px;
        background: rgba(255,255,255,0.05);
        border-radius: 10px;
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: var(--at-orange);
        width: 33.33%;
        transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 0 10px var(--at-orange-glow);
    }

    /* FORMULARIO */
    form {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .wizard-step {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: fadeIn 0.4s ease-in-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-group-custom {
        width: 100%;
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

    .form-label-custom {
        display: block;
        color: #94a3b8;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
        text-align: left;
    }

    /* Inputs y Selects Homogéneos */
    .input-custom {
        background-color: #0d1117 !important;
        border: 1px solid var(--at-border) !important;
        color: white !important;
        padding: 12px 16px !important;
        border-radius: 12px !important;
        text-align: left;
        width: 100%;
        transition: all 0.3s ease;
    }

    .input-custom:focus {
        border-color: var(--at-orange) !important;
        box-shadow: 0 0 15px var(--at-orange-glow) !important;
        outline: none;
    }

    /* Estilo para las opciones del Select */
    select.input-custom option {
        background-color: #1f2937;
        color: white;
    }

    /* BOTONES PILL ATRIUM */
    .button-group {
        display: flex;
        gap: 15px;
        width: 100%;
        margin-top: 30px;
    }

    .btn-atrium-main {
        background-color: var(--at-orange) !important;
        color: white !important;
        border: none;
        border-radius: 100px;
        padding: 16px 0;
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        flex: 1;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
        cursor: pointer;
    }

    .btn-atrium-main:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 15px 30px rgba(249, 115, 22, 0.4);
    }

    .btn-atrium-secondary {
        background-color: transparent !important;
        color: #94a3b8 !important;
        border: 1px solid #334155 !important;
        border-radius: 100px;
        padding: 16px 0;
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        flex: 1;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-atrium-secondary:hover {
        color: white !important;
        border-color: white !important;
        background-color: rgba(255, 255, 255, 0.05) !important;
    }

    /* Cajas de preguntas Step 2 */
    .question-card {
        background: rgba(255,255,255,0.02);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 20px;
        width: 100%;
    }

    .login-footer {
        width: 100%;
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        text-align: center;
    }

    .login-link {
        color: #64748b;
        font-size: 0.85rem;
        text-decoration: none;
        transition: 0.3s;
    }

    .login-link strong { color: var(--at-orange); font-weight: 700; }
    .login-link:hover strong { color: white; }

    .alert-register {
        width: 100%;
        background: rgba(239, 68, 68, 0.1);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 12px;
        font-size: 0.85rem;
        padding: 15px;
        margin-bottom: 25px;
        text-align: center;
    }

    /* Evitar inversión en emojis para que no se vean opacos */
    .no-invert { filter: none !important; }
</style>

<div class="auth-page-container">
    <div class="register-card shadow-2xl">
        <div style="font-size: 45px; margin-bottom: 10px; text-align: center;"><span role="img" class="no-invert">📝</span></div>
        <h1 class="register-title">Registro <span class="brand-highlight">Atrium</span></h1>
        
        <div class="step-indicator-container">
            <p class="register-subtitle" id="step-indicator">Paso 1 de 3: Datos Personales</p>
            <div class="progress-track">
                <div class="progress-fill" id="progress-bar"></div>
            </div>
        </div>

        <% if (locals.error) { %>
            <div class="alert alert-register" role="alert">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/registro" method="POST" id="formWizard">
            
            <!-- PASO 1: DATOS PERSONALES -->
            <div id="step1" class="wizard-step">
                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Nombre</label>
                            <input type="text" name="nombre" class="form-control input-custom" required placeholder="Ej: Juan">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Apellido</label>
                            <input type="text" name="apellido" class="form-control input-custom" required placeholder="Ej: Pérez">
                        </div>
                    </div>
                </div>

                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Cédula</label>
                            <input type="text" name="cedula" class="form-control input-custom" required placeholder="V-00000000">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Correo (Gmail)</label>
                            <input type="email" name="gmail" class="form-control input-custom" required placeholder="usuario@gmail.com">
                        </div>
                    </div>
                </div>

                <hr class="w-100 border-secondary border-opacity-25 my-3">

                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Usuario / Login</label>
                            <input type="text" name="login" class="form-control input-custom" required placeholder="Nombre de usuario">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Contraseña</label>
                            <input type="password" name="password" class="form-control input-custom" required placeholder="••••••••">
                        </div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3 text-start w-100" style="color: var(--at-orange); font-size: 0.85rem; text-transform: uppercase; font-weight: 800; letter-spacing: 1px;">Dirección</h5>

                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">País</label>
                            <select name="pais" class="form-control input-custom" required>
                                <option value="Venezuela" selected>Venezuela</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Estado / Provincia</label>
                            <input type="text" name="estado_residencia" class="form-control input-custom" required placeholder="Ej: Bolívar">
                        </div>
                    </div>
                </div>

                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Ciudad</label>
                            <input type="text" name="ciudad" class="form-control input-custom" required placeholder="Ej: Puerto Ordaz">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Municipio</label>
                            <input type="text" name="municipio" class="form-control input-custom" required placeholder="Ej: Caroní">
                        </div>
                    </div>
                </div>

                <div class="row w-100 mb-2">
                    <div class="col-12">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Calle / Urb / Nro. Casa</label>
                            <input type="text" name="calle" class="form-control input-custom" required placeholder="Ej: Urb. Los Olivos, Calle Roma, Casa #12">
                        </div>
                    </div>
                </div>

                <div class="button-group">
                    <button type="button" class="btn-atrium-main" onclick="cambiarPaso(1, 2)">
                        Continuar a Seguridad ➔
                    </button>
                </div>
            </div>

            <!-- PASO 2: SEGURIDAD -->
            <div id="step2" class="wizard-step" style="display: none;">
                <p class="text-white small text-center mb-4">Seleccione 3 preguntas distintas para recuperar su clave en el futuro.</p>

                <% for(let i = 1; i <= 3; i++) { %>
                    <div class="question-card shadow-sm">
                        <label class="form-label-custom" style="color: #ffffff;">Pregunta de Seguridad <%= i %></label>
                        
                        <select name="preguntasIds[]" class="form-control input-custom mb-3" required>
                            <option value="" disabled selected>-- Haz clic para elegir una pregunta --</option>
                            <% if (locals.preguntas) { %>
                                <% preguntas.forEach(item => { %>
                                    <option value="<%= item.Id %>"><%= item.pregunta %></option>
                                <% }) %>
                            <% } %>
                        </select>

                        <input type="text" name="respuestas[]" class="form-control input-custom" required placeholder="Escriba su respuesta secreta...">
                    </div>
                <% } %>

                <div class="button-group">
                    <button type="button" class="btn-atrium-secondary" onclick="cambiarPaso(2, 1)">
                        🡨 Atrás
                    </button>
                    <button type="button" class="btn-atrium-main" onclick="validarPaso2()">
                        Continuar al Pago ➔
                    </button>
                </div>
            </div>

            <!-- PASO 3: PAGO -->
            <div id="step3" class="wizard-step" style="display: none;">
                <!-- MODIFICADO: Estilo alert cambiado a Naranja Atrium -->
                <div class="alert-custom mb-4 p-3 text-center" style="background: rgba(249, 115, 22, 0.05); border-radius: 12px; border: 1px solid rgba(249, 115, 22, 0.3); color: #f97316; font-size: 0.85rem;">
                    <i class="bi bi-info-circle me-2"></i> Se realizará un cargo único de <strong>$10.00</strong> por membresía anual.
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Número de Tarjeta de Crédito</label>
                    <input type="text" name="nroTarjeta" class="form-control input-custom" required placeholder="0000 1111 2222 3333" minlength="15" maxlength="19">
                </div>
                
                <div class="row w-100">
                    <div class="col-md-6">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Código CVV</label>
                            <input type="password" name="cvv" class="form-control input-custom" required placeholder="123" maxlength="4">
                        </div>
                    </div>
                    <div class="col-md-6 d-flex align-items-center justify-content-center">
                        <span style="font-size: 30px;"><span role="img">💳 🔒</span></span>
                    </div>
                </div>

                <div class="button-group">
                    <button type="button" class="btn-atrium-secondary" onclick="cambiarPaso(3, 2)">
                        🡨 Atrás
                    </button>
                    <!-- MODIFICADO: Botón cambiado a Naranja Atrium -->
                    <button type="submit" class="btn-atrium-main" style="background-color: #f97316 !important; box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);">
                        ✓ Finalizar Registro
                    </button>
                </div>
            </div>

        </form>
        
        <div class="login-footer">
            <a href="/auth/login" class="login-link">
                ¿Ya tiene cuenta? <strong>Inicie sesión aquí</strong>
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
    function cambiarPaso(pasoActual, pasoSiguiente) {
        if (pasoSiguiente > pasoActual) {
            const currentStepDiv = document.getElementById('step' + pasoActual);
            const inputs = currentStepDiv.querySelectorAll('input[required]');
            
            for (let input of inputs) {
                if (!input.value) {
                    input.reportValidity(); 
                    return; 
                }
            }
        }

        document.getElementById('step1').style.display = 'none';
        document.getElementById('step2').style.display = 'none';
        document.getElementById('step3').style.display = 'none';

        document.getElementById('step' + pasoSiguiente).style.display = 'flex';

        const titulos = ["Datos Personales", "Seguridad", "Método de Pago"];
        document.getElementById('step-indicator').innerText = `Paso ${pasoSiguiente} de 3: ${titulos[pasoSiguiente - 1]}`;
        
        const progreso = (pasoSiguiente / 3) * 100;
        document.getElementById('progress-bar').style.width = progreso + '%';
    }

    function validarPaso2() {
        const step2 = document.getElementById('step2');
        const selects = step2.querySelectorAll('select[name="preguntasIds[]"]');
        const inputs = step2.querySelectorAll('input[name="respuestas[]"]');

        for (let i = 0; i < 3; i++) {
            if (!selects[i].value) {
                selects[i].reportValidity();
                return;
            }
            if (!inputs[i].value) {
                inputs[i].reportValidity();
                return;
            }
        }

        const valoresElegidos = [selects[0].value, selects[1].value, selects[2].value];
        const valoresUnicos = new Set(valoresElegidos); 

        if (valoresUnicos.size < 3) {
            alert("⚠️ Por favor, selecciona 3 preguntas diferentes. No puedes repetir la misma pregunta.");
            return; 
        }
        cambiarPaso(2, 3);
    }
</script>